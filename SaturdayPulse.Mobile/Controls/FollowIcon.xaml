<?xml version="1.0" encoding="utf-8" ?>

<ContentView
    x:Class="SaturdayPulse.Controls.FollowIcon"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="ThisControl">

    <Label FontSize="{Binding IconSize, Source={x:Reference ThisControl}}"
           VerticalOptions="Center"
           HorizontalOptions="Center">

        <Label.Triggers>

            <!-- FOLLOWED -->
            <DataTrigger
                TargetType="Label"
                Binding="{Binding IsFollowed, Source={x:Reference ThisControl}}"
                Value="True">

                <Setter Property="Text"
                        Value="{Binding GlyphOn, Source={x:Reference ThisControl}}" />

                <Setter Property="TextColor"
                        Value="{Binding ColorOn, Source={x:Reference ThisControl}}" />

            </DataTrigger>

            <!-- NOT FOLLOWED -->
            <DataTrigger
                TargetType="Label"
                Binding="{Binding IsFollowed, Source={x:Reference ThisControl}}"
                Value="False">

                <Setter Property="Text"
                        Value="{Binding GlyphOff, Source={x:Reference ThisControl}}" />

                <Setter Property="TextColor"
                        Value="{Binding ColorOff, Source={x:Reference ThisControl}}" />

            </DataTrigger>

        </Label.Triggers>

    </Label>

</ContentView>