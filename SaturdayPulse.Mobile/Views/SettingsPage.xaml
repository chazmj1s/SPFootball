<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SaturdayPulse.Models"
             xmlns:helpers="clr-namespace:SaturdayPulse.Helpers"
             xmlns:controls="clr-namespace:SaturdayPulse.Controls"
             x:Class="SaturdayPulse.Views.SettingsPage"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,24">

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- ROW 0: Page title                                   -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Label Grid.Row="0"
               Text="Settings"
               FontSize="20" FontAttributes="Bold"
               Padding="12,10"
               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- ROW 1: Accordion sections                           -->
        <!-- ═══════════════════════════════════════════════════ -->
        <RefreshView Grid.Row="1"
                     Command="{Binding RefreshCommand}"
                     IsRefreshing="False">
            <ScrollView>
                <VerticalStackLayout Spacing="0">

                    <!-- ─────────────────────────────────────── -->
                    <!-- SECTION: Following                      -->
                    <!-- ─────────────────────────────────────── -->

                    <Grid ColumnDefinitions="*,24"
                          Padding="12,10"
                          BackgroundColor="{AppThemeBinding Light=#F0EBF8, Dark=#2A2040}">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleSectionCommand}"
                                                  CommandParameter="Following" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0"
                               Text="Following"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               FontSize="14" FontAttributes="Bold"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding IsFollowingExpanded}" Value="True">
                                    <Setter Property="Text" Value="▲" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding IsFollowingExpanded}" Value="False">
                                    <Setter Property="Text" Value="▼" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Grid>

                    <VerticalStackLayout IsVisible="{Binding IsFollowingExpanded}" Spacing="0">

                        <Grid ColumnDefinitions="*,*"
                              BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#1E1E1E}">

                            <VerticalStackLayout Grid.Column="0" Spacing="0">
                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectViewCommand}" CommandParameter="Teams" />
                                </VerticalStackLayout.GestureRecognizers>
                                <Label Text="Teams" FontSize="13" FontAttributes="Bold"
                                       HorizontalOptions="Center" Padding="0,8">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsTeamsView}" Value="True">
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsTeamsView}" Value="False">
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light=#888888, Dark=#666666}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                                <BoxView HeightRequest="2" HorizontalOptions="Fill">
                                    <BoxView.Triggers>
                                        <DataTrigger TargetType="BoxView" Binding="{Binding IsTeamsView}" Value="True">
                                            <Setter Property="Color" Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="BoxView" Binding="{Binding IsTeamsView}" Value="False">
                                            <Setter Property="Color" Value="Transparent" />
                                        </DataTrigger>
                                    </BoxView.Triggers>
                                </BoxView>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="0">
                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectViewCommand}" CommandParameter="Games" />
                                </VerticalStackLayout.GestureRecognizers>
                                <Label Text="Games" FontSize="13" FontAttributes="Bold"
                                       HorizontalOptions="Center" Padding="0,8">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsGamesView}" Value="True">
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsGamesView}" Value="False">
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light=#888888, Dark=#666666}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                                <BoxView HeightRequest="2" HorizontalOptions="Fill">
                                    <BoxView.Triggers>
                                        <DataTrigger TargetType="BoxView" Binding="{Binding IsGamesView}" Value="True">
                                            <Setter Property="Color" Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="BoxView" Binding="{Binding IsGamesView}" Value="False">
                                            <Setter Property="Color" Value="Transparent" />
                                        </DataTrigger>
                                    </BoxView.Triggers>
                                </BoxView>
                            </VerticalStackLayout>

                        </Grid>

                        <!-- Teams list -->
                        <CollectionView ItemsSource="{Binding Teams}"
                                        IsVisible="{Binding IsTeamsView}"
                                        ItemSizingStrategy="MeasureAllItems">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:TeamInfo">
                                    <Grid ColumnDefinitions="*,Auto" Padding="12,8">
                                        <Label Grid.Column="0"
                                               Text="{Binding TeamName}"
                                               FontSize="13" VerticalOptions="Center" />
                                        <Label Grid.Column="1"
                                               Text="{Binding IsFollowed, Converter={StaticResource FollowTeamGlyphConverter}}"
                                               TextColor="{Binding IsFollowed, Converter={StaticResource FollowTeamColorConverter}}"
                                               FontSize="{StaticResource TeamIconSize}"
                                               VerticalOptions="Center">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleFollowCommand}"
                                                    CommandParameter="{Binding TeamID}" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!-- Games list -->
                        <VerticalStackLayout IsVisible="{Binding IsGamesView}" Spacing="0">

                            <Picker ItemsSource="{Binding TierFilters}"
                                    SelectedItem="{Binding SelectedTier}"
                                    Margin="12,8" FontSize="13" />

                            <CollectionView ItemsSource="{Binding Games}"
                                            ItemSizingStrategy="MeasureAllItems">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:RivalryInfo">
                                        <VerticalStackLayout Spacing="0">

                                            <!-- Title + ★ favorite + tier badge -->
                                            <Grid ColumnDefinitions="*,Auto,Auto" Padding="10,5,10,2">

                                                <Label Grid.Column="0"
                                                       Text="{Binding DisplayName}"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       VerticalOptions="Center"
                                                       LineBreakMode="TailTruncation" />

                                                <!-- Star: favorite this game -->
                                                <controls:FollowGameIcon
                                                        Grid.Column="1"
                                                        IsFollowed="{Binding IsGameFavorited}"
                                                        VerticalOptions="Center"
                                                        HorizontalOptions="End"
                                                        Margin="8,0">
                                                    <controls:FollowGameIcon.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.TogglePersonalCommand}"
                                                            CommandParameter="{Binding .}" />
                                                    </controls:FollowGameIcon.GestureRecognizers>
                                                </controls:FollowGameIcon>

                                                <Label Grid.Column="2"
                                                       Text="{Binding TierBadge}"
                                                       FontSize="16"
                                                       VerticalOptions="Center"
                                                       HorizontalOptions="End" />
                                            </Grid>

                                            <!-- Team rows: heart · name · series/upset · margin/swing -->
                                            <Grid ColumnDefinitions="28,*,110,90"
                                                  RowDefinitions="Auto,Auto"
                                                  Padding="10,2,10,5">

                                                <!-- Heart: follow team 1 -->
                                                <controls:FollowTeamIcon
                                                        Grid.Row="0" Grid.Column="0"
                                                        IsFollowed="{Binding Team1IsFollowed}"
                                                        VerticalOptions="Center"
                                                        HorizontalOptions="Center">
                                                    <controls:FollowTeamIcon.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleFollowCommand}"
                                                            CommandParameter="{Binding Team1Id}" />
                                                    </controls:FollowTeamIcon.GestureRecognizers>
                                                </controls:FollowTeamIcon>

                                                <Label Grid.Row="0" Grid.Column="1"
                                                       Text="{Binding Team1Name}"
                                                       FontSize="13"
                                                       VerticalOptions="Center"
                                                       LineBreakMode="TailTruncation" />

                                                <Label Grid.Row="0" Grid.Column="2"
                                                       Text="{Binding DisplaySeries}"
                                                       FontSize="9"
                                                       TextColor="{AppThemeBinding Light=#666666, Dark=#999999}"
                                                       VerticalOptions="Center" />

                                                <Label Grid.Row="0" Grid.Column="3"
                                                       Text="{Binding DisplayAvgMargin}"
                                                       FontSize="9"
                                                       TextColor="{AppThemeBinding Light=#888888, Dark=#777777}"
                                                       VerticalOptions="Center"
                                                       HorizontalOptions="End" />

                                                <!-- Heart: follow team 2 -->
                                                <controls:FollowTeamIcon
                                                        Grid.Row="1" Grid.Column="0"
                                                        IsFollowed="{Binding Team2IsFollowed}"
                                                        VerticalOptions="Center"
                                                        HorizontalOptions="Center">
                                                    <controls:FollowTeamIcon.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleFollowCommand}"
                                                            CommandParameter="{Binding Team2Id}" />
                                                    </controls:FollowTeamIcon.GestureRecognizers>
                                                </controls:FollowTeamIcon>

                                                <Label Grid.Row="1" Grid.Column="1"
                                                       Text="{Binding Team2Name}"
                                                       FontSize="13"
                                                       VerticalOptions="Center"
                                                       LineBreakMode="TailTruncation" />

                                                <Label Grid.Row="1" Grid.Column="2"
                                                       Text="{Binding DisplayUpsetRate}"
                                                       FontSize="9"
                                                       TextColor="{AppThemeBinding Light=#666666, Dark=#999999}"
                                                       VerticalOptions="Center" />

                                                <Label Grid.Row="1" Grid.Column="3"
                                                       Text="{Binding DisplayAvgSwing}"
                                                       FontSize="9"
                                                       TextColor="{AppThemeBinding Light=#888888, Dark=#777777}"
                                                       VerticalOptions="Center"
                                                       HorizontalOptions="End" />
                                            </Grid>

                                            <!-- Row divider -->
                                            <BoxView HeightRequest="1" Opacity="0.12"
                                                     Color="{AppThemeBinding Light=Black, Dark=White}" />

                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                        </VerticalStackLayout>

                    </VerticalStackLayout>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" Opacity="0.1"
                             Color="{AppThemeBinding Light=Black, Dark=White}" />

                    <!-- ─────────────────────────────────────── -->
                    <!-- SECTION: User Config                    -->
                    <!-- ─────────────────────────────────────── -->

                    <Grid ColumnDefinitions="*,24"
                          Padding="12,10"
                          BackgroundColor="{AppThemeBinding Light=#F0EBF8, Dark=#2A2040}">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleSectionCommand}"
                                                  CommandParameter="UserConfig" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0"
                               Text="User Config"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               FontSize="14" FontAttributes="Bold"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding IsUserConfigExpanded}" Value="True">
                                    <Setter Property="Text" Value="▲" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding IsUserConfigExpanded}" Value="False">
                                    <Setter Property="Text" Value="▼" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Grid>

                    <VerticalStackLayout IsVisible="{Binding IsUserConfigExpanded}"
                                         Padding="16,12" Spacing="16">

                        <!-- Show Favorites First -->
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="Show favorites first"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
                                <Label Text="Followed teams and starred games appear at the top of each list."
                                       FontSize="11"
                                       TextColor="{AppThemeBinding Light=#888888, Dark=#777777}"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding ShowFavoritesFirst}"
                                    VerticalOptions="Center"
                                    OnColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                        </Grid>

                        <BoxView HeightRequest="1" Opacity="0.1"
                                 Color="{AppThemeBinding Light=Black, Dark=White}" />

                        <!-- Default Week -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Default week"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
                            <Label Text="Which week to show when the app launches."
                                   FontSize="11"
                                   TextColor="{AppThemeBinding Light=#888888, Dark=#777777}"
                                   LineBreakMode="WordWrap" />
                            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,*" ColumnSpacing="8" Margin="0,4,0,0">

                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectDefaultWeekCommand}"
                                                          CommandParameter="Week1" />
                                </Grid.GestureRecognizers>

                                <Ellipse Grid.Column="0" WidthRequest="14" HeightRequest="14" VerticalOptions="Center">
                                    <Ellipse.Triggers>
                                        <DataTrigger TargetType="Ellipse"
                                                     Binding="{Binding DefaultWeek}" Value="Week1">
                                            <Setter Property="Fill"
                                                    Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                                            <Setter Property="StrokeThickness" Value="0" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Ellipse"
                                                     Binding="{Binding DefaultWeek}" Value="Current">
                                            <Setter Property="Fill" Value="Transparent" />
                                            <Setter Property="Stroke"
                                                    Value="{AppThemeBinding Light=#888888, Dark=#666666}" />
                                            <Setter Property="StrokeThickness" Value="1.5" />
                                        </DataTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <Label Grid.Column="1" Text="Week 1" FontSize="13" VerticalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding DefaultWeek}" Value="Week1">
                                            <Setter Property="TextColor"
                                                    Value="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding DefaultWeek}" Value="Current">
                                            <Setter Property="TextColor"
                                                    Value="{AppThemeBinding Light=#888888, Dark=#666666}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                                <BoxView Grid.Column="2" Color="Transparent" />

                                <Ellipse Grid.Column="3" WidthRequest="14" HeightRequest="14" VerticalOptions="Center">
                                    <Ellipse.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SelectDefaultWeekCommand}"
                                                              CommandParameter="Current" />
                                    </Ellipse.GestureRecognizers>
                                    <Ellipse.Triggers>
                                        <DataTrigger TargetType="Ellipse"
                                                     Binding="{Binding DefaultWeek}" Value="Current">
                                            <Setter Property="Fill"
                                                    Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                                            <Setter Property="StrokeThickness" Value="0" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Ellipse"
                                                     Binding="{Binding DefaultWeek}" Value="Week1">
                                            <Setter Property="Fill" Value="Transparent" />
                                            <Setter Property="Stroke"
                                                    Value="{AppThemeBinding Light=#888888, Dark=#666666}" />
                                            <Setter Property="StrokeThickness" Value="1.5" />
                                        </DataTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <Label Grid.Column="4" Text="Current" FontSize="13" VerticalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding DefaultWeek}" Value="Current">
                                            <Setter Property="TextColor"
                                                    Value="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding DefaultWeek}" Value="Week1">
                                            <Setter Property="TextColor"
                                                    Value="{AppThemeBinding Light=#888888, Dark=#666666}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                                <BoxView Grid.Column="5" Color="Transparent" />

                            </Grid>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Opacity="0.1"
                                 Color="{AppThemeBinding Light=Black, Dark=White}" />

                        <!-- Default Conference -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Default conference"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
                            <Label Text="Conference filter applied when the app launches."
                                   FontSize="11"
                                   TextColor="{AppThemeBinding Light=#888888, Dark=#777777}"
                                   LineBreakMode="WordWrap" />
                            <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="6" Margin="0,2,0,0">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectDefaultConferenceCommand}" />
                                </Grid.GestureRecognizers>
                                <Label Grid.Column="0"
                                       Text="{Binding DefaultConference}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="▾" FontSize="14"
                                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Opacity="0.1"
                                 Color="{AppThemeBinding Light=Black, Dark=White}" />

                        <!-- Default Team (My Teams' primary team) -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Default team"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
                            <Label Text="Your primary team on the My Teams tab — always shown first, and what My Teams opens to if it's your default landing page."
                                   FontSize="11"
                                   TextColor="{AppThemeBinding Light=#888888, Dark=#777777}"
                                   LineBreakMode="WordWrap" />
                            <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="6" Margin="0,2,0,0">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectDefaultTeamCommand}" />
                                </Grid.GestureRecognizers>
                                <Label Grid.Column="0"
                                       Text="{Binding DefaultTeamDisplay}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="▾" FontSize="14"
                                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Opacity="0.1"
                                 Color="{AppThemeBinding Light=Black, Dark=White}" />

                        <!-- Default Landing Page -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Default landing page"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
                            <Label Text="Which tab the app opens to."
                                   FontSize="11"
                                   TextColor="{AppThemeBinding Light=#888888, Dark=#777777}"
                                   LineBreakMode="WordWrap" />
                            <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="6" Margin="0,2,0,0">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectDefaultLandingPageCommand}" />
                                </Grid.GestureRecognizers>
                                <Label Grid.Column="0"
                                       Text="{Binding DefaultLandingPageDisplay}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="▾" FontSize="14"
                                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </VerticalStackLayout>

                    </VerticalStackLayout>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" Opacity="0.1"
                             Color="{AppThemeBinding Light=Black, Dark=White}" />

                    <!-- ─────────────────────────────────────── -->
                    <!-- SECTION: More Cool Stuff                -->
                    <!-- ─────────────────────────────────────── -->

                    <Grid ColumnDefinitions="*,24"
                          Padding="12,10"
                          BackgroundColor="{AppThemeBinding Light=#F0EBF8, Dark=#2A2040}">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleSectionCommand}"
                                                  CommandParameter="UserProfile" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0"
                               Text="User Profile"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               FontSize="14" FontAttributes="Bold"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsUserProfileExpanded}" Value="True">
                                    <Setter Property="Text" Value="▲" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding IsUserProfileExpanded}" Value="False">
                                    <Setter Property="Text" Value="▼" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Grid>

                    <VerticalStackLayout IsVisible="{Binding IsUserProfileExpanded}"
                                         Padding="16,12" Spacing="16">

                        <!-- Handle -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Handle"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
                            <Label Text="Your display name. Pick one anytime — this is just what shows instead of an auto-generated ID."
                                   FontSize="11"
                                   TextColor="{AppThemeBinding Light=#888888, Dark=#777777}"
                                   LineBreakMode="WordWrap" />
                            <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="6" Margin="0,2,0,0">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding EditHandleCommand}" />
                                </Grid.GestureRecognizers>
                                <Label Grid.Column="0"
                                       Text="{Binding Handle}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="▾" FontSize="14"
                                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Opacity="0.1"
                                 Color="{AppThemeBinding Light=Black, Dark=White}" />

                        <!-- Email -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Email"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
                            <Label Text="Used for account recovery and, if you opt in elsewhere, updates."
                                   FontSize="11"
                                   TextColor="{AppThemeBinding Light=#888888, Dark=#777777}"
                                   LineBreakMode="WordWrap" />
                            <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="6" Margin="0,2,0,0">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding EditEmailCommand}" />
                                </Grid.GestureRecognizers>
                                <Label Grid.Column="0"
                                       Text="{Binding EmailDisplay}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="▾" FontSize="14"
                                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Opacity="0.1"
                                 Color="{AppThemeBinding Light=Black, Dark=White}" />

                        <!-- Phone -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Phone number"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
                            <Label Text="Optional. Asked separately whether it's OK to text game and score alerts."
                                   FontSize="11"
                                   TextColor="{AppThemeBinding Light=#888888, Dark=#777777}"
                                   LineBreakMode="WordWrap" />
                            <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="6" Margin="0,2,0,0">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding EditPhoneCommand}" />
                                </Grid.GestureRecognizers>
                                <Label Grid.Column="0"
                                       Text="{Binding PhoneDisplay}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="▾" FontSize="14"
                                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                                       VerticalOptions="Center" />
                            </Grid>
                            <Label Text="Text alerts: on"
                                   FontSize="11"
                                   TextColor="{AppThemeBinding Light=#888888, Dark=#777777}"
                                   IsVisible="{Binding MarketingSmsConsent}" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" Opacity="0.1"
                             Color="{AppThemeBinding Light=Black, Dark=White}" />

                    <!-- ─────────────────────────────────────── -->
                    <!-- SECTION: Debug Log                      -->
                    <!-- ─────────────────────────────────────── -->

                    <Grid ColumnDefinitions="*,24"
                          Padding="12,10"
                          BackgroundColor="{AppThemeBinding Light=#F0EBF8, Dark=#2A2040}">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleSectionCommand}"
                                                  CommandParameter="DebugLog" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0"
                               Text="Debug Log"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               FontSize="14" FontAttributes="Bold"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding IsDebugLogExpanded}" Value="True">
                                    <Setter Property="Text" Value="▲" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding IsDebugLogExpanded}" Value="False">
                                    <Setter Property="Text" Value="▼" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Grid>

                    <VerticalStackLayout IsVisible="{Binding IsDebugLogExpanded}" Spacing="0">

                        <!-- Toolbar: entry count + clear -->
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="12,8"
                              BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#1E1E1E}">
                            <Label Grid.Column="0"
                                   Text="{Binding LogEntryCount, StringFormat='{0} entries'}"
                                   FontSize="11" Opacity="0.6"
                                   VerticalOptions="Center" />
                            <Border Grid.Column="1"
                                    StrokeShape="RoundRectangle 4"
                                    Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#444444}"
                                    StrokeThickness="1"
                                    Padding="10,4">
                                <Label Text="Clear"
                                       FontSize="11"
                                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ClearLogCommand}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>
                        </Grid>

                        <!-- Log entries — newest first -->
                        <ScrollView HeightRequest="300"
                                    BackgroundColor="{AppThemeBinding Light=#1A1A1A, Dark=#0D0D0D}">
                            <CollectionView ItemsSource="{Binding LogEntries}"
                                            ItemSizingStrategy="MeasureAllItems">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="helpers:LogEntry">
                                        <Label Text="{Binding Display}"
                                               FontSize="9"
                                               TextColor="{Binding LevelColor}"
                                               Padding="8,2"
                                               LineBreakMode="WordWrap" />
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                                <CollectionView.EmptyView>
                                    <Label Text="No log entries yet."
                                           FontSize="11" Opacity="0.5"
                                           HorizontalOptions="Center"
                                           Padding="0,20"
                                           TextColor="#888888" />
                                </CollectionView.EmptyView>
                            </CollectionView>
                        </ScrollView>

                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- ROW 2: Status bar                                   -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" HeightRequest="24"
              BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2B2B2B}">
            <Label Text="{Binding StatusMessage}"
                   Padding="8,0" FontSize="10" Opacity="0.5"
                   VerticalOptions="Center" HorizontalOptions="Start"
                   TextColor="{AppThemeBinding Light=#444444, Dark=#AAAAAA}" />
        </Grid>

    </Grid>
</ContentPage>
