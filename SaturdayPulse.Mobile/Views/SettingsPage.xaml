<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SaturdayPulse.Models"
             xmlns:controls="clr-namespace:SaturdayPulse.Controls"
             x:Class="SaturdayPulse.Views.SettingsPage"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,24">

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- ROW 0: Page title                                   -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Label Grid.Row="0"
               Text="Settings"
               FontSize="20" FontAttributes="Bold"
               Padding="12,10"
               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- ROW 1: Accordion sections                           -->
        <!-- ═══════════════════════════════════════════════════ -->
        <RefreshView Grid.Row="1"
                     Command="{Binding RefreshCommand}"
                     IsRefreshing="{Binding IsLoading}">
            <ScrollView>
                <VerticalStackLayout Spacing="0">

                    <!-- ─────────────────────────────────────── -->
                    <!-- SECTION: Following                      -->
                    <!-- ─────────────────────────────────────── -->

                    <!-- Section header -->
                    <Grid ColumnDefinitions="*,24"
                          Padding="12,10"
                          BackgroundColor="{AppThemeBinding Light=#F0EBF8, Dark=#2A2040}">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleSectionCommand}"
                                                  CommandParameter="Following" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0"
                               Text="Following"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               FontSize="14" FontAttributes="Bold"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding IsFollowingExpanded}" Value="True">
                                    <Setter Property="Text" Value="▲" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding IsFollowingExpanded}" Value="False">
                                    <Setter Property="Text" Value="▼" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Grid>

                    <!-- Section body -->
                    <VerticalStackLayout IsVisible="{Binding IsFollowingExpanded}" Spacing="0">

                        <!-- Teams | Games toggle -->
                        <Grid ColumnDefinitions="*,*"
                              BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#1E1E1E}"
                              Padding="8,4">

                            <Border Grid.Column="0"
                                    Margin="0,0,4,0" Padding="0,6"
                                    StrokeShape="RoundRectangle 6" StrokeThickness="0">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsTeamsView}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsTeamsView}" Value="False">
                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#E0E0E0, Dark=#333333}" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label Text="Teams" FontSize="13" FontAttributes="Bold" HorizontalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsTeamsView}" Value="True">
                                            <Setter Property="TextColor" Value="White" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsTeamsView}" Value="False">
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light=#555555, Dark=#AAAAAA}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectViewCommand}" CommandParameter="Teams" />
                                </Border.GestureRecognizers>
                            </Border>

                            <Border Grid.Column="1"
                                    Margin="4,0,0,0" Padding="0,6"
                                    StrokeShape="RoundRectangle 6" StrokeThickness="0">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsGamesView}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsGamesView}" Value="False">
                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#E0E0E0, Dark=#333333}" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label Text="Games" FontSize="13" FontAttributes="Bold" HorizontalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsGamesView}" Value="True">
                                            <Setter Property="TextColor" Value="White" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsGamesView}" Value="False">
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light=#555555, Dark=#AAAAAA}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectViewCommand}" CommandParameter="Games" />
                                </Border.GestureRecognizers>
                            </Border>

                        </Grid>

                        <!-- Loading indicator -->
                        <ActivityIndicator IsRunning="{Binding IsLoading}"
                                           IsVisible="{Binding IsLoading}"
                                           HorizontalOptions="Center"
                                           Margin="0,16" />

                        <!-- ═══════════════════════════════════ -->
                        <!-- TEAMS VIEW                          -->
                        <!-- ═══════════════════════════════════ -->
                        <VerticalStackLayout IsVisible="{Binding IsTeamsView}" Spacing="0">

                            <!-- Conference filter -->
                            <Grid ColumnDefinitions="Auto,*"
                                  Padding="10,6,10,4" ColumnSpacing="8">
                                <Label Grid.Column="0" Text="Conference"
                                       FontSize="11" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"
                                       VerticalOptions="Center" />
                                <Picker Grid.Column="1"
                                        ItemsSource="{Binding ConferenceFilters}"
                                        SelectedItem="{Binding SelectedConference}"
                                        FontSize="13" HeightRequest="32"
                                        VerticalOptions="Center" />
                            </Grid>

                            <!-- Column headers -->
                            <Grid ColumnDefinitions="28,*,60"
                                  Padding="10,4,10,4"
                                  BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#2A2A2A}">
                                <Label Grid.Column="0" Text="" />
                                <Label Grid.Column="1" Text="Team"
                                       FontSize="11" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="Conf"
                                       FontSize="11" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Grid>

                            <!-- Teams list -->
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Teams}" Spacing="0">
                                <BindableLayout.EmptyView>
                                    <Label Text="No teams found" FontSize="14"
                                           HorizontalOptions="Center" Padding="20" />
                                </BindableLayout.EmptyView>
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:TeamInfo">
                                        <Grid ColumnDefinitions="28,*,60" Padding="10,7,10,7">

                                            <controls:FollowTeamIcon
                                                Grid.Column="0"
                                                IsFollowed="{Binding IsFollowed}"
                                                VerticalOptions="Center"
                                                HorizontalOptions="Center">
                                                <controls:FollowTeamIcon.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleFollowCommand}"
                                                        CommandParameter="{Binding TeamID}" />
                                                </controls:FollowTeamIcon.GestureRecognizers>
                                            </controls:FollowTeamIcon>

                                            <Label Grid.Column="1"
                                                   Text="{Binding TeamName}"
                                                   FontSize="13"
                                                   VerticalOptions="Center"
                                                   LineBreakMode="TailTruncation" />

                                            <Label Grid.Column="2"
                                                   Text="{Binding ConferenceAbbr}"
                                                   FontSize="11"
                                                   TextColor="{AppThemeBinding Light=#666666, Dark=#999999}"
                                                   HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                        </VerticalStackLayout>

                        <!-- ═══════════════════════════════════ -->
                        <!-- GAMES VIEW                          -->
                        <!-- ═══════════════════════════════════ -->
                        <VerticalStackLayout IsVisible="{Binding IsGamesView}" Spacing="0">

                            <!-- Tier filter -->
                            <Grid ColumnDefinitions="Auto,*"
                                  Padding="10,6,10,4" ColumnSpacing="8">
                                <Label Grid.Column="0" Text="Tier"
                                       FontSize="11" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"
                                       VerticalOptions="Center" />
                                <Picker Grid.Column="1"
                                        ItemsSource="{Binding TierFilters}"
                                        SelectedItem="{Binding SelectedTier}"
                                        FontSize="13" HeightRequest="32"
                                        VerticalOptions="Center" />
                            </Grid>

                            <!-- Column headers -->
                            <Grid ColumnDefinitions="28,*,110,90,32"
                                  Padding="10,4,10,4"
                                  BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#2A2A2A}">
                                <Label Grid.Column="0" Text="" />
                                <Label Grid.Column="1" Text="Team"
                                       FontSize="11" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="Series"
                                       FontSize="11" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="3" Text="Stats"
                                       FontSize="11" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}"
                                       HorizontalOptions="End" VerticalOptions="Center" />
                                <Label Grid.Column="4" Text="" />
                            </Grid>

                            <!-- Games list -->
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Games}" Spacing="0">
                                <BindableLayout.EmptyView>
                                    <Label Text="No games followed yet" FontSize="16"
                                           HorizontalOptions="Center" Padding="20" />
                                </BindableLayout.EmptyView>
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <VerticalStackLayout Spacing="0">

                                            <!-- Rivalry header: name + tier badge + star -->
                                            <Grid ColumnDefinitions="*,Auto,32" Padding="10,5,10,2">
                                                <Label Grid.Column="0"
                                                       Text="{Binding RivalryName}"
                                                       FontSize="12" FontAttributes="Bold"
                                                       VerticalOptions="Center"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding TierBadge}"
                                                       FontSize="16"
                                                       VerticalOptions="Center"
                                                       HorizontalOptions="End" />

                                                <!-- Star: follow this rivalry/game -->
                                                <controls:FollowGameIcon
                                                    Grid.Column="2"
                                                    IsFollowed="{Binding IsGameFavorited}"
                                                    HorizontalOptions="Center"
                                                    VerticalOptions="Center">
                                                    <controls:FollowGameIcon.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.TogglePersonalCommand}"
                                                            CommandParameter="{Binding .}" />
                                                    </controls:FollowGameIcon.GestureRecognizers>
                                                </controls:FollowGameIcon>
                                            </Grid>

                                            <!-- Team rows -->
                                            <Grid ColumnDefinitions="28,*,110,90"
                                                  RowDefinitions="Auto,Auto"
                                                  Padding="10,2,10,5">

                                                <!-- Heart: follow team 1 -->
                                                <controls:FollowTeamIcon
                                                    Grid.Row="0" Grid.Column="0"
                                                    IsFollowed="{Binding Team1IsFollowed}"
                                                    VerticalOptions="Center"
                                                    HorizontalOptions="Center">
                                                    <controls:FollowTeamIcon.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleFollowCommand}"
                                                            CommandParameter="{Binding Team1Id}" />
                                                    </controls:FollowTeamIcon.GestureRecognizers>
                                                </controls:FollowTeamIcon>

                                                <Label Grid.Row="0" Grid.Column="1"
                                                       Text="{Binding Team1Name}"
                                                       FontSize="13" VerticalOptions="Center"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Grid.Row="0" Grid.Column="2"
                                                       Text="{Binding DisplaySeries}"
                                                       FontSize="9"
                                                       TextColor="{AppThemeBinding Light=#666666, Dark=#999999}"
                                                       VerticalOptions="Center" />
                                                <Label Grid.Row="0" Grid.Column="3"
                                                       Text="{Binding DisplayAvgMargin}"
                                                       FontSize="9"
                                                       TextColor="{AppThemeBinding Light=#888888, Dark=#777777}"
                                                       VerticalOptions="Center" HorizontalOptions="End" />

                                                <!-- Heart: follow team 2 -->
                                                <controls:FollowTeamIcon
                                                    Grid.Row="1" Grid.Column="0"
                                                    IsFollowed="{Binding Team2IsFollowed}"
                                                    VerticalOptions="Center"
                                                    HorizontalOptions="Center">
                                                    <controls:FollowTeamIcon.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleFollowCommand}"
                                                            CommandParameter="{Binding Team2Id}" />
                                                    </controls:FollowTeamIcon.GestureRecognizers>
                                                </controls:FollowTeamIcon>

                                                <Label Grid.Row="1" Grid.Column="1"
                                                       Text="{Binding Team2Name}"
                                                       FontSize="13" VerticalOptions="Center"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Grid.Row="1" Grid.Column="2"
                                                       Text="{Binding DisplayUpsetRate}"
                                                       FontSize="9"
                                                       TextColor="{AppThemeBinding Light=#666666, Dark=#999999}"
                                                       VerticalOptions="Center" />
                                                <Label Grid.Row="1" Grid.Column="3"
                                                       Text="{Binding DisplayAvgSwing}"
                                                       FontSize="9"
                                                       TextColor="{AppThemeBinding Light=#888888, Dark=#777777}"
                                                       VerticalOptions="Center" HorizontalOptions="End" />
                                            </Grid>

                                            <BoxView HeightRequest="1" Opacity="0.12"
                                                     Color="{AppThemeBinding Light=Black, Dark=White}" />

                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                        </VerticalStackLayout>

                    </VerticalStackLayout>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" Opacity="0.1"
                             Color="{AppThemeBinding Light=Black, Dark=White}" />

                    <!-- ─────────────────────────────────────── -->
                    <!-- SECTION: User Configuration             -->
                    <!-- ─────────────────────────────────────── -->

                    <Grid ColumnDefinitions="*,24"
                          Padding="12,10"
                          BackgroundColor="{AppThemeBinding Light=#F0EBF8, Dark=#2A2040}">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleSectionCommand}"
                                                  CommandParameter="UserConfig" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0"
                               Text="User Configuration"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               FontSize="14" FontAttributes="Bold"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsUserConfigExpanded}" Value="True">
                                    <Setter Property="Text" Value="▲" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding IsUserConfigExpanded}" Value="False">
                                    <Setter Property="Text" Value="▼" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Grid>

                    <VerticalStackLayout IsVisible="{Binding IsUserConfigExpanded}"
                                         Padding="16,12" Spacing="16">

                        <!-- Show Favorites First -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding ShowFavoritesFirst}"
                                      VerticalOptions="Center"
                                      Color="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="Show favorites first"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
                                <Label Text="Starred games and followed teams sort to the top in Scores and Rankings."
                                       FontSize="11"
                                       TextColor="{AppThemeBinding Light=#888888, Dark=#777777}"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Grid>

                    </VerticalStackLayout>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" Opacity="0.1"
                             Color="{AppThemeBinding Light=Black, Dark=White}" />

                    <!-- ─────────────────────────────────────── -->
                    <!-- SECTION: More Cool Stuff                -->
                    <!-- ─────────────────────────────────────── -->

                    <Grid ColumnDefinitions="*,24"
                          Padding="12,10"
                          BackgroundColor="{AppThemeBinding Light=#F0EBF8, Dark=#2A2040}">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleSectionCommand}"
                                                  CommandParameter="MoreCoolStuff" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0"
                               Text="More Cool Stuff"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               FontSize="14" FontAttributes="Bold"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsMoreCoolStuffExpanded}" Value="True">
                                    <Setter Property="Text" Value="▲" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding IsMoreCoolStuffExpanded}" Value="False">
                                    <Setter Property="Text" Value="▼" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Grid>

                    <VerticalStackLayout IsVisible="{Binding IsMoreCoolStuffExpanded}"
                                         Padding="16,12">
                        <Label Text="Coming soon..."
                               FontSize="13" FontAttributes="Italic"
                               TextColor="{AppThemeBinding Light=#999999, Dark=#666666}" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- ROW 2: Status bar                                   -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" HeightRequest="24"
              BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2B2B2B}">
            <Label Text="{Binding StatusMessage}"
                   Padding="8,0" FontSize="10" Opacity="0.5"
                   VerticalOptions="Center" HorizontalOptions="Start"
                   TextColor="{AppThemeBinding Light=#444444, Dark=#AAAAAA}" />
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               HeightRequest="16" WidthRequest="16"
                               HorizontalOptions="End" VerticalOptions="Center"
                               Margin="8,0" />
        </Grid>

    </Grid>
</ContentPage>
