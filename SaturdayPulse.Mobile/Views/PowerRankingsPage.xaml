<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SaturdayPulse.Models"
             xmlns:controls="clr-namespace:SaturdayPulse.Controls"
             xmlns:converters="clr-namespace:SaturdayPulse.Converters"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Charts;assembly=Syncfusion.Maui.Charts"
             x:Class="SaturdayPulse.Views.PowerRankingsPage"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False">

  <Grid RowDefinitions="Auto,*,24">

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 0: Column headers                               -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Grid Grid.Row="0"
          Padding="4,3"
          BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2B2B2B}"
          ColumnDefinitions="44,22,*,55,70,60">

      <Label Grid.Column="0" Text="Rank ↕" FontAttributes="Bold" FontSize="10">
        <Label.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SortColumnCommand}" CommandParameter="Rank"/>
        </Label.GestureRecognizers>
      </Label>
      <Label Grid.Column="1" Text="" />
      <Label Grid.Column="2" Text="Team ↕" FontAttributes="Bold" FontSize="10">
        <Label.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SortColumnCommand}" CommandParameter="Team"/>
        </Label.GestureRecognizers>
      </Label>
      <Label Grid.Column="3" Text="Rec ↕" FontAttributes="Bold" FontSize="10">
        <Label.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SortColumnCommand}" CommandParameter="Record"/>
        </Label.GestureRecognizers>
      </Label>
      <Label Grid.Column="4" Text="Rating ↕" FontAttributes="Bold" FontSize="10">
        <Label.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SortColumnCommand}" CommandParameter="Rating"/>
        </Label.GestureRecognizers>
      </Label>
      <Label Grid.Column="5" Text="SOS ↕" FontAttributes="Bold" FontSize="10">
        <Label.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SortColumnCommand}" CommandParameter="SOS"/>
        </Label.GestureRecognizers>
      </Label>

    </Grid>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 1: Rankings list with pull-to-refresh           -->
    <!-- ═══════════════════════════════════════════════════ -->
    <RefreshView Grid.Row="1"
                 Command="{Binding RefreshCommand}"
                 IsRefreshing="{Binding IsBusy}">

      <CollectionView ItemsSource="{Binding FilteredTeams}"
                      SelectionMode="None">

        <CollectionView.ItemTemplate>
          <DataTemplate x:DataType="models:TeamRanking">
            <VerticalStackLayout Spacing="0">

              <!-- ── Main row ── -->
              <Grid Padding="4,3"
                    ColumnDefinitions="44,22,*,55,70,60"
                    BackgroundColor="{Binding IsOddRow, Converter={StaticResource OddRowBackgroundConverter}}">

                <!-- Rank badge -->
                <Grid Grid.Column="0"
                      Padding="2,2"
                      HeightRequest="26"
                      WidthRequest="40"
                      HorizontalOptions="Center"
                      VerticalOptions="Center">
                  <BoxView CornerRadius="3"
                           Color="{Binding IsTop25, Converter={StaticResource BoolToColorConverter}}" />
                  <Label Text="{Binding OverallRank}"
                         FontSize="11" FontAttributes="Bold" TextColor="White"
                         HorizontalOptions="Center" VerticalOptions="Center" />
                </Grid>

                <!-- Heart: follow team -->
                <Label Grid.Column="1"
                       Text="{Binding IsFollowed, Converter={StaticResource FollowTeamGlyphConverter}}"
                       TextColor="{Binding IsFollowed, Converter={StaticResource FollowTeamColorConverter}}"
                       FontSize="{StaticResource TeamIconSize}"
                       VerticalOptions="Center" HorizontalOptions="Center">
                  <Label.GestureRecognizers>
                    <TapGestureRecognizer
                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleFollowCommand}"
                        CommandParameter="{Binding .}" />
                  </Label.GestureRecognizers>
                </Label>

                <!-- Team + Conf · Tier -->
                <VerticalStackLayout Grid.Column="2" Spacing="0" VerticalOptions="Center">
                  <Label Text="{Binding TeamName}"
                         FontSize="12" FontAttributes="Bold" LineBreakMode="TailTruncation"/>
                  <Label Text="{Binding DisplayConferenceTier}"
                         FontSize="10" Opacity="0.6" LineBreakMode="TailTruncation"/>
                </VerticalStackLayout>

                <Label Grid.Column="3" Text="{Binding Record}"
                       FontSize="11" VerticalOptions="Center"/>
                <Label Grid.Column="4" Text="{Binding DisplayRank}"
                       FontSize="11" FontAttributes="Bold" VerticalOptions="Center"/>
                <Label Grid.Column="5" Text="{Binding DisplaySOS}"
                       FontSize="11" VerticalOptions="Center"/>

              </Grid>

              <!-- ── Toggle bar: Trend/Pedigree | Season Arc | Offense/Defense ── -->
              <Grid ColumnDefinitions="*,*,*"
                    Padding="4,2,8,2"
                    BackgroundColor="{Binding IsOddRow, Converter={StaticResource OddRowBackgroundConverter}}">

                <!-- LEFT: Trend / Pedigree -->
                <Label Grid.Column="0"
                       IsVisible="{Binding HasTrendData}"
                       FontSize="10" HorizontalOptions="Start"
                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
                  <Label.FormattedText>
                    <FormattedString>
                      <Span Text="Trend / Pedigree" />
                      <Span Text="  " />
                      <Span Text="{Binding TrendExpandIcon}" FontSize="8" />
                    </FormattedString>
                  </Label.FormattedText>
                  <Label.GestureRecognizers>
                    <TapGestureRecognizer
                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleTrendExpandCommand}"
                        CommandParameter="{Binding .}" />
                  </Label.GestureRecognizers>
                </Label>

                <!-- CENTER: Season Arc -->
                <Label Grid.Column="1"
                       FontSize="10" HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
                  <Label.FormattedText>
                    <FormattedString>
                      <Span Text="Season Arc" />
                      <Span Text="  " />
                      <Span Text="{Binding ArcExpandIcon}" FontSize="8" />
                    </FormattedString>
                  </Label.FormattedText>
                  <Label.GestureRecognizers>
                    <TapGestureRecognizer
                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleArcExpandCommand}"
                        CommandParameter="{Binding .}" />
                  </Label.GestureRecognizers>
                </Label>

                <!-- RIGHT: Offense / Defense -->
                <Label Grid.Column="2"
                       IsVisible="{Binding HasOffenseDefenseData}"
                       FontSize="10" HorizontalOptions="End"
                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
                  <Label.FormattedText>
                    <FormattedString>
                      <Span Text="Offense / Defense" />
                      <Span Text="  " />
                      <Span Text="{Binding StatsExpandIcon}" FontSize="8" />
                    </FormattedString>
                  </Label.FormattedText>
                  <Label.GestureRecognizers>
                    <TapGestureRecognizer
                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleStatsExpandCommand}"
                        CommandParameter="{Binding .}" />
                  </Label.GestureRecognizers>
                </Label>

              </Grid>

              <!-- ── Trend / Pedigree expanded panel ── -->
              <Border IsVisible="{Binding IsTrendExpanded}"
                      StrokeThickness="1"
                      Stroke="{AppThemeBinding Light=#D8D8D8, Dark=#3A3A3A}"
                      BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#202020}"
                      Margin="4,0,4,6">

                <VerticalStackLayout Spacing="0">

                  <Grid ColumnDefinitions="*,Auto,Auto" Padding="12,8,12,2">

                    <Label Grid.Column="0"
                           Text="Trend / Pedigree History"
                           FontSize="10" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />

                    <Label Grid.Column="1"
                           Text="{Binding Record}"
                           FontSize="9" Opacity="0.6"
                           Margin="0,0,10,0" />

                    <VerticalStackLayout Grid.Column="2" Spacing="0">
                      <Label Text="{Binding TrendRating, StringFormat='Trend {0:F4}'}"
                             FontSize="9" FontAttributes="Bold"
                             HorizontalTextAlignment="End"
                             TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                      <Label Text="{Binding PedigreeRating, StringFormat='Pedigree {0:F4}'}"
                             FontSize="9" FontAttributes="Bold"
                             HorizontalTextAlignment="End"
                             TextColor="{AppThemeBinding Light=#3D7AB5, Dark=#5FA8E8}" />
                    </VerticalStackLayout>

                  </Grid>

                  <chart:SfCartesianChart HeightRequest="160" Margin="8,0,8,8">

                    <chart:SfCartesianChart.XAxes>
                      <chart:CategoryAxis ShowMajorGridLines="False" LabelPlacement="BetweenTicks" />
                    </chart:SfCartesianChart.XAxes>

                    <chart:SfCartesianChart.YAxes>
                      <chart:NumericalAxis Minimum="0" Maximum="1.2" Interval="0.2" ShowMajorGridLines="True" />
                    </chart:SfCartesianChart.YAxes>

                    <chart:SplineSeries
                        ItemsSource="{Binding TrendPoints}"
                        XBindingPath="Index" YBindingPath="Value"
                        Label="Trend"
                        Fill="{AppThemeBinding Light=#7A4DFF, Dark=#B388FF}"
                        StrokeWidth="3.5" EnableTooltip="True" />

                    <chart:SplineSeries
                        ItemsSource="{Binding PedigreePoints}"
                        XBindingPath="Index" YBindingPath="Value"
                        Label="Pedigree"
                        Fill="{AppThemeBinding Light=#C89B3C, Dark=#FFD166}"
                        StrokeWidth="2.5" EnableTooltip="True" />

                    <chart:SfCartesianChart.Legend>
                      <chart:ChartLegend Placement="Bottom" />
                    </chart:SfCartesianChart.Legend>

                  </chart:SfCartesianChart>

                </VerticalStackLayout>

              </Border>

              <!-- ── Season Arc expanded panel ── -->
              <Border IsVisible="{Binding IsArcExpanded}"
                      StrokeThickness="1"
                      Stroke="{AppThemeBinding Light=#C8E6C9, Dark=#2E4A35}"
                      BackgroundColor="{AppThemeBinding Light=#F1F8F2, Dark=#1A2A1E}"
                      Margin="4,0,4,6">

                <VerticalStackLayout Spacing="0">

                  <Grid ColumnDefinitions="*,Auto" Padding="12,8,12,2">
                    <Label Grid.Column="0"
                           Text="Season Arc"
                           FontSize="10" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#2E8B57, Dark=#4CAF84}" />
                    <Label Grid.Column="1"
                           Text="{Binding Record}"
                           FontSize="9" Opacity="0.6" />
                  </Grid>

                  <chart:SfCartesianChart HeightRequest="170" Margin="8,0,8,8">

                    <chart:SfCartesianChart.XAxes>
                        <chart:NumericalAxis ShowMajorGridLines="False"
                            Minimum="1" Interval="2">
                            <chart:NumericalAxis.Title>
                                <chart:ChartAxisTitle Text="Week" FontSize="9" />
                            </chart:NumericalAxis.Title>
                        </chart:NumericalAxis>
                    </chart:SfCartesianChart.XAxes>

                    <chart:SfCartesianChart.YAxes>
                        <chart:NumericalAxis x:Name="RatingAxis"
                           Minimum="-1" Maximum="2"
                           Interval="0.5"
                           ShowMajorGridLines="True" />
                        <chart:NumericalAxis x:Name="PctAxis"
                           Minimum="0" Maximum="1.2"
                           Interval="0.2"
                           ShowMajorGridLines="False"
                           CrossesAt="9999" />
                        <chart:NumericalAxis x:Name="SOSAxis"
                           Minimum="0" Maximum="1.2"
                           Interval="0.2"
                           ShowMajorGridLines="False"
                           CrossesAt="9999" />
                    </chart:SfCartesianChart.YAxes>

                    <chart:SplineSeries
                        ItemsSource="{Binding ArcRankingPoints}"
                        XBindingPath="Index" YBindingPath="Value"
                        Label="Rating"
                        YAxisName="RatingAxis"
                        Fill="{AppThemeBinding Light=#7A4DFF, Dark=#B388FF}"
                        StrokeWidth="3" EnableTooltip="True" />

                    <chart:SplineSeries
                        ItemsSource="{Binding ArcSosPoints}"
                        XBindingPath="Index" YBindingPath="Value"
                        Label="SOS"
                        YAxisName="SOSAxis"
                        Fill="{AppThemeBinding Light=#FF4444, Dark=#FF6B6B}"
                        StrokeWidth="2.5" EnableTooltip="True" />

                    <chart:SplineSeries
                        ItemsSource="{Binding ArcWinPctPoints}"
                        XBindingPath="Index" YBindingPath="Value"
                        Label="Win %"
                        YAxisName="PctAxis"
                        Fill="{AppThemeBinding Light=#FFE500, Dark=#FFE500}"
                        StrokeWidth="2" EnableTooltip="True" />

                    <chart:SfCartesianChart.Legend>
                      <chart:ChartLegend Placement="Bottom" />
                    </chart:SfCartesianChart.Legend>

                  </chart:SfCartesianChart>

                </VerticalStackLayout>

              </Border>

              <!-- ── Offense / Defense expanded panel ── -->
              <VerticalStackLayout IsVisible="{Binding IsStatsExpanded}"
                                   Spacing="0"
                                   BackgroundColor="{AppThemeBinding Light=#F0EBFF, Dark=#1A1520}">

                <Grid ColumnDefinitions="*,*,*" Padding="8,6,8,4" ColumnSpacing="4">
                  <VerticalStackLayout Grid.Column="0" Spacing="1">
                    <Label Text="Offensive Rank" FontSize="9" Opacity="0.6" />
                    <Label Text="{Binding OffensiveRankDisplay}"
                           FontSize="10" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                  </VerticalStackLayout>
                  <VerticalStackLayout Grid.Column="1" Spacing="1">
                    <Label Text="Avg. Points Scored" FontSize="9" Opacity="0.6" />
                    <Label Text="{Binding AvgPointsScored, StringFormat='{0:F1}'}"
                           FontSize="10" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
                  </VerticalStackLayout>
                  <VerticalStackLayout Grid.Column="2" Spacing="1">
                    <Label Text="Offensive Index (Std-Z)" FontSize="9" Opacity="0.6" />
                    <Label Text="{Binding OffensiveZScore, StringFormat='{0:F4}'}"
                           FontSize="10" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
                  </VerticalStackLayout>
                </Grid>

                <BoxView HeightRequest="1" Opacity="0.08" Margin="8,0"
                         Color="{AppThemeBinding Light=Black, Dark=White}" />

                <Grid ColumnDefinitions="*,*,*" Padding="8,4,8,6" ColumnSpacing="4">
                  <VerticalStackLayout Grid.Column="0" Spacing="1">
                    <Label Text="Defensive Rank" FontSize="9" Opacity="0.6" />
                    <Label Text="{Binding DefensiveRankDisplay}"
                           FontSize="10" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                  </VerticalStackLayout>
                  <VerticalStackLayout Grid.Column="1" Spacing="1">
                    <Label Text="Avg. Points Allowed" FontSize="9" Opacity="0.6" />
                    <Label Text="{Binding AvgPointsAllowed, StringFormat='{0:F1}'}"
                           FontSize="10" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
                  </VerticalStackLayout>
                  <VerticalStackLayout Grid.Column="2" Spacing="1">
                    <Label Text="Defensive Index (Std-Z)" FontSize="9" Opacity="0.6" />
                    <Label Text="{Binding DefensiveZScore, StringFormat='{0:F4}'}"
                           FontSize="10" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
                  </VerticalStackLayout>
                </Grid>

              </VerticalStackLayout>

              <BoxView HeightRequest="1" Opacity="0.10"
                       Color="{AppThemeBinding Light=Black, Dark=White}" />

            </VerticalStackLayout>
          </DataTemplate>
        </CollectionView.ItemTemplate>

        <CollectionView.EmptyView>
          <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="20">
            <Label Text="No teams found" FontSize="18" HorizontalOptions="Center"/>
            <Label Text="{Binding StatusMessage}" FontSize="14" Opacity="0.7"
                   HorizontalOptions="Center" Margin="0,10,0,0"/>
          </VerticalStackLayout>
        </CollectionView.EmptyView>

      </CollectionView>

    </RefreshView>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 2: Status bar                                   -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Grid Grid.Row="2" HeightRequest="24"
          BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2B2B2B}">
      <Label Text="{Binding StatusMessage}"
             Padding="8,0" FontSize="10" Opacity="0.7"
             VerticalOptions="Center" HorizontalOptions="Start"/>
      <ActivityIndicator IsRunning="{Binding IsBusy}"
                         IsVisible="{Binding IsBusy}"
                         HeightRequest="16" WidthRequest="16"
                         HorizontalOptions="End" VerticalOptions="Center"
                         Margin="8,0"/>
    </Grid>

  </Grid>

</ContentPage>
