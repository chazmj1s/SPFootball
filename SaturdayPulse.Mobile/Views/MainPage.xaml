<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:SaturdayPulse.ViewModels"
             x:Class="SaturdayPulse.Views.MainPage"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False">

  <Grid RowDefinitions="Auto,Auto,2,Auto,Auto,*"
        BackgroundColor="{AppThemeBinding Light=#1A1A2E, Dark=#0D0D1A}">

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 0: App title                                    -->
    <!-- ═══════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" ColumnDefinitions="44,*,44" Padding="8,6,8,6">
            <Image Grid.Column="0"
             Source="applogo.png"
             Aspect="AspectFit"
             VerticalOptions="Fill" 
             HorizontalOptions="Start" />
            <Label Grid.Column="1"
             Text="J1S Sports"
             FontSize="16" FontAttributes="Bold"
             HorizontalOptions="Center"
             HorizontalTextAlignment="Center"
             VerticalOptions="Center"
             TextColor="#BF5700" />
            <!-- Gear icon — Settings' only tab-strip entry point now that it's
                 out of TabItems (see MainPage.xaml.cs / MainViewModel.cs).
                 Column 2 was already reserved (44,*,44) but unused before this. -->
            <Label Grid.Column="2"
             Text="&#9881;"
             FontSize="12"
             HorizontalOptions="Center"
             VerticalOptions="Center"
             TextColor="#BF5700">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenSettingsCommand}" />
                </Label.GestureRecognizers>
            </Label>
        </Grid>

        <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 1: Year pill + Week strip                       -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Grid Grid.Row="1"
          ColumnDefinitions="64,*"
          BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#252525}">

      <!-- Year pill -->
      <Border Grid.Column="0"
              StrokeShape="RoundRectangle 6"
              Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#444444}"
              StrokeThickness="1"
              BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
              Margin="6,4,2,4"
              Padding="6,3">
        <Grid ColumnDefinitions="*,Auto">
          <Label Grid.Column="0"
                 Text="{Binding SelectedYear}"
                 FontSize="12" FontAttributes="Bold"
                 VerticalOptions="Center" />
          <Label Grid.Column="1"
                 Text="▾" FontSize="10"
                 TextColor="{AppThemeBinding Light=#888888, Dark=#777777}"
                 VerticalOptions="Center" Margin="2,0,0,0" />
          <Grid.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding SelectYearCommand}" />
          </Grid.GestureRecognizers>
        </Grid>
      </Border>

      <!-- Week strip -->
      <ScrollView Grid.Column="1"
                  x:Name="WeekScrollView"
                  Orientation="Horizontal"
                  HorizontalScrollBarVisibility="Never">
        <HorizontalStackLayout Spacing="0" Padding="2,0"
                               BindableLayout.ItemsSource="{Binding Weeks}">
          <BindableLayout.ItemTemplate>
            <DataTemplate x:DataType="viewmodels:WeekItem">
              <Grid Padding="1,0" MinimumWidthRequest="38">
                <VerticalStackLayout Spacing="0">
                  <Label Text="{Binding Label}"
                         FontSize="11" FontAttributes="Bold"
                         HorizontalOptions="Center" Padding="6,6">
                    <Label.Triggers>
                      <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="TextColor" Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                      </DataTrigger>
                      <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="False">
                        <Setter Property="TextColor" Value="{AppThemeBinding Light=#555555, Dark=#AAAAAA}" />
                      </DataTrigger>
                    </Label.Triggers>
                  </Label>
                  <BoxView HeightRequest="2" HorizontalOptions="Fill"
                           Color="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                           IsVisible="{Binding IsSelected}" />
                </VerticalStackLayout>
                <Grid.GestureRecognizers>
                  <TapGestureRecognizer
                      Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.SelectWeekCommand}"
                      CommandParameter="{Binding Week}" />
                </Grid.GestureRecognizers>
              </Grid>
            </DataTemplate>
          </BindableLayout.ItemTemplate>
        </HorizontalStackLayout>
      </ScrollView>

    </Grid>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 2: Loading indicator                             -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Grid Grid.Row="2" x:Name="LoadingBarHost"
          IsVisible="{Binding IsLoading}"
          BackgroundColor="{AppThemeBinding Light=#E8E8E8, Dark=#1A1A1A}">
      <BoxView x:Name="LoadingBar"
               HeightRequest="2"
               WidthRequest="80"
               HorizontalOptions="Start"
               VerticalOptions="Fill"
               Color="#BF5700"
               TranslationX="0" />
    </Grid>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 3: Conference filter pill                       -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Border Grid.Row="3"
            StrokeShape="RoundRectangle 6"
            Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#444444}"
            StrokeThickness="1"
            BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
            Margin="10,4,10,4" Padding="8,3">
      <Grid ColumnDefinitions="*,Auto">
        <Label Grid.Column="0"
               Text="{Binding SelectedConference}"
               FontSize="13" FontAttributes="Bold"
               VerticalOptions="Center" LineBreakMode="TailTruncation" />
        <Label Grid.Column="1"
               Text="▾" FontSize="11"
               TextColor="{AppThemeBinding Light=#888888, Dark=#777777}"
               VerticalOptions="Center" Margin="4,0,0,0" />
        <Grid.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SelectConferenceCommand}" />
        </Grid.GestureRecognizers>
      </Grid>
    </Border>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 4: Tab strip                                    -->
    <!-- ═══════════════════════════════════════════════════ -->
    <ScrollView Grid.Row="4"
                Orientation="Horizontal"
                HorizontalScrollBarVisibility="Never"
                BackgroundColor="{AppThemeBinding Light=#1A1A2E, Dark=#0D0D1A}">
      <HorizontalStackLayout Spacing="0" Padding="6,0"
                             BindableLayout.ItemsSource="{Binding TabItems}">
        <BindableLayout.ItemTemplate>
          <DataTemplate x:DataType="viewmodels:TabItem">
            <Grid Padding="2,0" MinimumWidthRequest="56">
              <VerticalStackLayout Spacing="0">
                <Label Text="{Binding Label}"
                       FontSize="12" FontAttributes="Bold"
                       HorizontalOptions="Center" Padding="10,10">
                  <Label.Triggers>
                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                      <Setter Property="TextColor" Value="White" />
                    </DataTrigger>
                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="False">
                      <Setter Property="TextColor" Value="#888899" />
                    </DataTrigger>
                  </Label.Triggers>
                </Label>
                <BoxView HeightRequest="2" HorizontalOptions="Fill"
                         IsVisible="{Binding IsSelected}" Color="#9B7EDE" />
              </VerticalStackLayout>
              <Grid.GestureRecognizers>
                <TapGestureRecognizer
                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.SelectTabCommand}"
                    CommandParameter="{Binding Index}" />
              </Grid.GestureRecognizers>
            </Grid>
          </DataTemplate>
        </BindableLayout.ItemTemplate>
      </HorizontalStackLayout>
    </ScrollView>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 5: Page host — AbsoluteLayout fills all space   -->
    <!-- ═══════════════════════════════════════════════════ -->
    <AbsoluteLayout Grid.Row="5"
                    x:Name="PageHost"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#121212}">
      <AbsoluteLayout.GestureRecognizers>
        <SwipeGestureRecognizer Direction="Left"  Command="{Binding NextTabCommand}" />
        <SwipeGestureRecognizer Direction="Right" Command="{Binding PreviousTabCommand}" />
      </AbsoluteLayout.GestureRecognizers>
    </AbsoluteLayout>

  </Grid>
</ContentPage>
