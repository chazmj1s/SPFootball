<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SaturdayPulse.Models"
             xmlns:viewmodels="clr-namespace:SaturdayPulse.ViewModels"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Charts;assembly=Syncfusion.Maui.Charts"
             x:Class="SaturdayPulse.Views.ProjectionsPage"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False">

  <Grid RowDefinitions="Auto,*,24">

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 0: Standings | Title Game toggle                -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Grid Grid.Row="0"
          ColumnDefinitions="*,*"
          BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#1E1E1E}"
          Padding="8,4">

      <Border Grid.Column="0"
              Margin="0,0,4,0" Padding="0,6"
              StrokeShape="RoundRectangle 6" StrokeThickness="0">
        <Border.Triggers>
          <DataTrigger TargetType="Border" Binding="{Binding IsStandingsView}" Value="True">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
          </DataTrigger>
          <DataTrigger TargetType="Border" Binding="{Binding IsStandingsView}" Value="False">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#E0E0E0, Dark=#333333}" />
          </DataTrigger>
        </Border.Triggers>
        <Label Text="Standings" FontSize="13" FontAttributes="Bold" HorizontalOptions="Center">
          <Label.Triggers>
            <DataTrigger TargetType="Label" Binding="{Binding IsStandingsView}" Value="True">
              <Setter Property="TextColor" Value="White" />
            </DataTrigger>
            <DataTrigger TargetType="Label" Binding="{Binding IsStandingsView}" Value="False">
              <Setter Property="TextColor" Value="{AppThemeBinding Light=#555555, Dark=#AAAAAA}" />
            </DataTrigger>
          </Label.Triggers>
        </Label>
        <Border.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SelectViewCommand}" CommandParameter="Standings" />
        </Border.GestureRecognizers>
      </Border>

      <Border Grid.Column="1"
              Margin="4,0,0,0" Padding="0,6"
              StrokeShape="RoundRectangle 6" StrokeThickness="0">
        <Border.Triggers>
          <DataTrigger TargetType="Border" Binding="{Binding IsChampionshipView}" Value="True">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
          </DataTrigger>
          <DataTrigger TargetType="Border" Binding="{Binding IsChampionshipView}" Value="False">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#E0E0E0, Dark=#333333}" />
          </DataTrigger>
        </Border.Triggers>
        <Label Text="Title Game" FontSize="13" FontAttributes="Bold" HorizontalOptions="Center">
          <Label.Triggers>
            <DataTrigger TargetType="Label" Binding="{Binding IsChampionshipView}" Value="True">
              <Setter Property="TextColor" Value="White" />
            </DataTrigger>
            <DataTrigger TargetType="Label" Binding="{Binding IsChampionshipView}" Value="False">
              <Setter Property="TextColor" Value="{AppThemeBinding Light=#555555, Dark=#AAAAAA}" />
            </DataTrigger>
          </Label.Triggers>
        </Label>
        <Border.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SelectViewCommand}" CommandParameter="Championship" />
        </Border.GestureRecognizers>
      </Border>

    </Grid>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 1: Content area with pull-to-refresh            -->
    <!-- ═══════════════════════════════════════════════════ -->

    <ActivityIndicator Grid.Row="1"
                       IsRunning="{Binding IsLoading}"
                       IsVisible="{Binding IsLoading}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />

    <!-- STANDINGS VIEW -->
    <RefreshView Grid.Row="1"
                 Command="{Binding RefreshCommand}"
                 IsRefreshing="{Binding IsLoading}"
                 IsVisible="{Binding IsStandingsView}">

      <CollectionView ItemsSource="{Binding Standings}">
        <CollectionView.ItemTemplate>
          <DataTemplate x:DataType="models:ProjectedTeamStanding">
            <VerticalStackLayout Spacing="0">

              <!-- ── Main row ── -->
              <Grid ColumnDefinitions="28,*,80,80"
                    Padding="8,4,16,4"
                    BackgroundColor="{Binding IsOddRow, Converter={StaticResource OddRowBackgroundConverter}}">

                <!-- Finish badge -->
                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 4" StrokeThickness="0"
                        WidthRequest="24" HeightRequest="24"
                        HorizontalOptions="Center" VerticalOptions="Center">
                  <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding IsQualifier}" Value="True">
                      <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                    </DataTrigger>
                    <DataTrigger TargetType="Border" Binding="{Binding IsQualifier}" Value="False">
                      <Setter Property="BackgroundColor" Value="Transparent" />
                    </DataTrigger>
                  </Border.Triggers>
                  <Label Text="{Binding FinishDisplay}" FontSize="10" FontAttributes="Bold"
                         HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.Triggers>
                      <DataTrigger TargetType="Label" Binding="{Binding IsQualifier}" Value="True">
                        <Setter Property="TextColor" Value="White" />
                      </DataTrigger>
                      <DataTrigger TargetType="Label" Binding="{Binding IsQualifier}" Value="False">
                        <Setter Property="TextColor" Value="{AppThemeBinding Light=#AAAAAA, Dark=#666666}" />
                      </DataTrigger>
                    </Label.Triggers>
                  </Label>
                </Border>

                <!-- Team name + conference + overall record stacked -->
                <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                  <Label FontSize="14" LineBreakMode="TailTruncation">
                    <Label.FormattedText>
                      <FormattedString>
                        <Span Text="{Binding TeamName}" />
                        <Span Text="  " />
                        <Span Text="{Binding Conference}" FontSize="10"
                              TextColor="{AppThemeBinding Light=#999999, Dark=#666666}" />
                      </FormattedString>
                    </Label.FormattedText>
                  </Label>
                  <!-- Overall record — only shown when populated -->
                  <Label IsVisible="{Binding HasOverallRecord}"
                         FontSize="10"
                         TextColor="{AppThemeBinding Light=#888888, Dark=#777777}">
                    <Label.FormattedText>
                      <FormattedString>
                        <Span Text="Overall  " />
                        <Span Text="{Binding OverallActualRecord}"
                              TextColor="{AppThemeBinding Light=#444444, Dark=#BBBBBB}" />
                        <Span Text="  →  "
                              TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#555555}" />
                        <Span Text="{Binding OverallProjectedRecord}"
                              TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                      </FormattedString>
                    </Label.FormattedText>
                  </Label>
                </VerticalStackLayout>

                <!-- Conf actual record -->
                <Label Grid.Column="2" FontSize="13" FontAttributes="Bold"
                       HorizontalOptions="End" VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}">
                  <Label.FormattedText>
                    <FormattedString>
                      <Span Text="A: " FontSize="10" FontAttributes="None"
                            TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#666666}" />
                      <Span Text="{Binding ActualRecord}" />
                    </FormattedString>
                  </Label.FormattedText>
                </Label>

                <!-- Conf projected record -->
                <Label Grid.Column="3" FontSize="13" FontAttributes="Bold"
                       HorizontalOptions="End" VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
                  <Label.FormattedText>
                    <FormattedString>
                      <Span Text="P: " FontSize="10" FontAttributes="None"
                            TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#666666}" />
                      <Span Text="{Binding ProjectedRecord}" />
                    </FormattedString>
                  </Label.FormattedText>
                </Label>

                <Grid.GestureRecognizers>
                  <TapGestureRecognizer
                      Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleTeamExpandCommand}"
                      CommandParameter="{Binding .}" />
                </Grid.GestureRecognizers>

              </Grid>

              <!-- ── Chart toggle bar ── -->
              <Grid ColumnDefinitions="*,*"
                    Padding="8,2,16,2"
                    BackgroundColor="{Binding IsOddRow, Converter={StaticResource OddRowBackgroundConverter}}">

                <!-- Win trajectory chart toggle -->
                <Label Grid.Column="0"
                       FontSize="10" HorizontalOptions="Start"
                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
                  <Label.FormattedText>
                    <FormattedString>
                      <Span Text="Win Trajectory" />
                      <Span Text="  " />
                      <Span Text="{Binding ChartExpandIcon}" FontSize="8" />
                    </FormattedString>
                  </Label.FormattedText>
                  <Label.GestureRecognizers>
                    <TapGestureRecognizer
                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleChartExpandCommand}"
                        CommandParameter="{Binding .}" />
                  </Label.GestureRecognizers>
                </Label>

                <!-- Game detail toggle -->
                <Label Grid.Column="1"
                       FontSize="10" HorizontalOptions="End"
                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
                  <Label.FormattedText>
                    <FormattedString>
                      <Span Text="Game Detail" />
                      <Span Text="  " />
                      <Span Text="{Binding ExpandIcon}" FontSize="8" />
                    </FormattedString>
                  </Label.FormattedText>
                  <Label.GestureRecognizers>
                    <TapGestureRecognizer
                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleTeamExpandCommand}"
                        CommandParameter="{Binding .}" />
                  </Label.GestureRecognizers>
                </Label>

              </Grid>

              <!-- ── Win trajectory chart ── -->
              <Border IsVisible="{Binding IsChartExpanded}"
                      StrokeThickness="1"
                      Stroke="{AppThemeBinding Light=#D8D8D8, Dark=#3A3A3A}"
                      BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#1A1A1A}"
                      Margin="4,0,4,4">
                <VerticalStackLayout Spacing="0">

                  <Grid ColumnDefinitions="*,Auto,Auto" Padding="12,6,12,2">
                    <Label Grid.Column="0"
                           Text="Win Trajectory"
                           FontSize="10" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                    <Label Grid.Column="1"
                           FontSize="9" Opacity="0.6" Margin="0,0,10,0">
                      <Label.FormattedText>
                        <FormattedString>
                          <Span Text="Conf  " />
                          <Span Text="{Binding ActualRecord}"
                                TextColor="{AppThemeBinding Light=#444444, Dark=#BBBBBB}" />
                          <Span Text=" → " />
                          <Span Text="{Binding ProjectedRecord}"
                                TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                        </FormattedString>
                      </Label.FormattedText>
                    </Label>
                    <Label Grid.Column="2"
                           IsVisible="{Binding HasOverallRecord}"
                           FontSize="9" Opacity="0.6">
                      <Label.FormattedText>
                        <FormattedString>
                          <Span Text="Overall  " />
                          <Span Text="{Binding OverallActualRecord}"
                                TextColor="{AppThemeBinding Light=#444444, Dark=#BBBBBB}" />
                          <Span Text=" → " />
                          <Span Text="{Binding OverallProjectedRecord}"
                                TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                        </FormattedString>
                      </Label.FormattedText>
                    </Label>
                  </Grid>

                  <chart:SfCartesianChart HeightRequest="150" Margin="8,0,8,8">

                    <chart:SfCartesianChart.XAxes>
                      <chart:NumericalAxis ShowMajorGridLines="False" Interval="2">
                        <chart:NumericalAxis.Title>
                          <chart:ChartAxisTitle Text="Week" FontSize="9" />
                        </chart:NumericalAxis.Title>
                      </chart:NumericalAxis>
                    </chart:SfCartesianChart.XAxes>

                    <chart:SfCartesianChart.YAxes>
                      <chart:NumericalAxis
                          Minimum="0"
                          Maximum="{Binding WinChartYMax}"
                          Interval="{Binding WinChartYInterval}"
                          ShowMajorGridLines="True" />
                    </chart:SfCartesianChart.YAxes>

                    <!-- Actual wins — solid line -->
                    <chart:SplineSeries
                        ItemsSource="{Binding ActualWinPoints}"
                        XBindingPath="Index" YBindingPath="Value"
                        Label="Actual"
                        Fill="{AppThemeBinding Light=#2E7D32, Dark=#66BB6A}"
                        StrokeWidth="3" EnableTooltip="True" />

                    <!-- Projected wins — dashed line -->
                    <chart:SplineSeries
                        ItemsSource="{Binding ProjectedWinPoints}"
                        XBindingPath="Index" YBindingPath="Value"
                        Label="Projected"
                        Fill="{AppThemeBinding Light=#7A4DFF, Dark=#B388FF}"
                        StrokeWidth="2" StrokeDashArray="6,3"
                        EnableTooltip="True" />

                    <chart:SfCartesianChart.Legend>
                      <chart:ChartLegend Placement="Bottom" />
                    </chart:SfCartesianChart.Legend>

                  </chart:SfCartesianChart>

                </VerticalStackLayout>
              </Border>

              <!-- ── Expanded game detail ── -->
              <VerticalStackLayout IsVisible="{Binding IsExpanded}"
                                   BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#1A1A1A}"
                                   Padding="8,4,16,4" Spacing="0"
                                   BindableLayout.ItemsSource="{Binding Games}">
                <BindableLayout.ItemTemplate>
                  <DataTemplate x:DataType="models:ProjectedGame">
                    <Grid ColumnDefinitions="28,*,60,80" Padding="0,3">
                      <Label Grid.Column="0" Text="{Binding Week, StringFormat='Wk{0}'}"
                             FontSize="10" TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#555555}"
                             VerticalOptions="Center" />
                      <Label Grid.Column="1" Text="{Binding OpponentDisplay}"
                             FontSize="12" VerticalOptions="Center" LineBreakMode="TailTruncation" />
                      <Label Grid.Column="2" Text="{Binding DisplayResult}"
                             FontSize="12" FontAttributes="Bold"
                             HorizontalOptions="End" VerticalOptions="Center">
                        <Label.Triggers>
                          <DataTrigger TargetType="Label" Binding="{Binding Result}" Value="W">
                            <Setter Property="TextColor" Value="{AppThemeBinding Light=#2E7D32, Dark=#66BB6A}" />
                          </DataTrigger>
                          <DataTrigger TargetType="Label" Binding="{Binding Result}" Value="L">
                            <Setter Property="TextColor" Value="{AppThemeBinding Light=#C62828, Dark=#EF5350}" />
                          </DataTrigger>
                        </Label.Triggers>
                      </Label>
                      <Label Grid.Column="3" Text="{Binding DisplayScore}"
                             FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                             TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                    </Grid>
                  </DataTemplate>
                </BindableLayout.ItemTemplate>
              </VerticalStackLayout>

              <BoxView HeightRequest="1" Opacity="0.10"
                       Color="{AppThemeBinding Light=Black, Dark=White}" />

            </VerticalStackLayout>
          </DataTemplate>
        </CollectionView.ItemTemplate>
        <CollectionView.EmptyView>
          <Label Text="No standings data" FontSize="14"
                 HorizontalOptions="Center" VerticalOptions="Center" />
        </CollectionView.EmptyView>
      </CollectionView>

    </RefreshView>

    <!-- TITLE GAME VIEW -->
    <RefreshView Grid.Row="1"
                 Command="{Binding RefreshCommand}"
                 IsRefreshing="{Binding IsLoading}"
                 IsVisible="{Binding IsChampionshipView}">

      <CollectionView ItemsSource="{Binding Championships}">
        <CollectionView.ItemTemplate>
          <DataTemplate x:DataType="models:ChampionshipMatchup">
            <VerticalStackLayout Spacing="0">

              <Grid BackgroundColor="{AppThemeBinding Light=#EBEBEB, Dark=#252525}" Padding="10,5">
                <Label Text="{Binding Conference}" FontSize="12" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
              </Grid>

              <Grid ColumnDefinitions="*,60,80" Padding="12,6,16,3">
                <Label Grid.Column="0" Text="{Binding Qualifier1.TeamName}"
                       FontSize="14" FontAttributes="Bold"
                       VerticalOptions="Center" LineBreakMode="TailTruncation" />
                <Label Grid.Column="1" Text="{Binding Qualifier1.ConferenceRecord}"
                       FontSize="13" HorizontalOptions="End" VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=#444444, Dark=#BBBBBB}" />
                <Label Grid.Column="2" Text="{Binding Qualifier1Method}"
                       FontSize="10" HorizontalOptions="End" VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#666666}" />
              </Grid>

              <Grid ColumnDefinitions="*,60,80" Padding="12,3,16,6">
                <Label Grid.Column="0" Text="{Binding Qualifier2.TeamName}"
                       FontSize="14" FontAttributes="Bold"
                       VerticalOptions="Center" LineBreakMode="TailTruncation" />
                <Label Grid.Column="1" Text="{Binding Qualifier2.ConferenceRecord}"
                       FontSize="13" HorizontalOptions="End" VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=#444444, Dark=#BBBBBB}" />
                <Label Grid.Column="2" Text="{Binding Qualifier2Method}"
                       FontSize="10" HorizontalOptions="End" VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#666666}" />
              </Grid>

              <Grid ColumnDefinitions="*,*" Padding="12,2,16,6">
                <Label Grid.Column="0" IsVisible="{Binding HasTiebreaker}"
                       FontSize="10" TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
                  <Label.FormattedText>
                    <FormattedString>
                      <Span Text="{Binding TiebreakerSummary}" />
                      <Span Text="  " />
                      <Span Text="{Binding ExpandIcon}" FontSize="8" />
                    </FormattedString>
                  </Label.FormattedText>
                  <Label.GestureRecognizers>
                    <TapGestureRecognizer
                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleMatchupExpandCommand}"
                        CommandParameter="{Binding .}" />
                  </Label.GestureRecognizers>
                </Label>
                <Label Grid.Column="1" IsVisible="{Binding HasContenders}"
                       FontSize="10" HorizontalOptions="End"
                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
                  <Label.FormattedText>
                    <FormattedString>
                      <Span Text="Contenders" />
                      <Span Text="  " />
                      <Span Text="{Binding ContendersExpandIcon}" FontSize="8" />
                    </FormattedString>
                  </Label.FormattedText>
                  <Label.GestureRecognizers>
                    <TapGestureRecognizer
                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleContendersExpandCommand}"
                        CommandParameter="{Binding .}" />
                  </Label.GestureRecognizers>
                </Label>
              </Grid>

              <!-- Tiebreaker log -->
              <VerticalStackLayout IsVisible="{Binding IsExpanded}"
                                   BackgroundColor="{AppThemeBinding Light=#F5F0FF, Dark=#1A1520}"
                                   Padding="12,4,16,8" Spacing="2"
                                   BindableLayout.ItemsSource="{Binding TiebreakerLog}">
                <BindableLayout.ItemTemplate>
                  <DataTemplate x:DataType="x:String">
                    <Label Text="{Binding .}" FontSize="10"
                           TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}" />
                  </DataTemplate>
                </BindableLayout.ItemTemplate>
              </VerticalStackLayout>

              <!-- Contenders -->
              <VerticalStackLayout IsVisible="{Binding IsContendersExpanded}"
                                   BackgroundColor="{AppThemeBinding Light=#F0F5FF, Dark=#151A20}"
                                   Padding="12,4,16,8" Spacing="2"
                                   BindableLayout.ItemsSource="{Binding Contenders}">
                <BindableLayout.ItemTemplate>
                  <DataTemplate x:DataType="models:ChampionshipContender">
                    <Grid ColumnDefinitions="*,60" Padding="0,2">
                      <Label Grid.Column="0" Text="{Binding TeamName}"
                             FontSize="12" VerticalOptions="Center" />
                      <Label Grid.Column="1" Text="{Binding ConferenceRecord}"
                             FontSize="12" FontAttributes="Bold"
                             HorizontalOptions="End" VerticalOptions="Center"
                             TextColor="{AppThemeBinding Light=#444444, Dark=#BBBBBB}" />
                    </Grid>
                  </DataTemplate>
                </BindableLayout.ItemTemplate>
              </VerticalStackLayout>

              <BoxView HeightRequest="1" Opacity="0.15"
                       Color="{AppThemeBinding Light=Black, Dark=White}" />

            </VerticalStackLayout>
          </DataTemplate>
        </CollectionView.ItemTemplate>
        <CollectionView.EmptyView>
          <Label Text="No championship data" FontSize="14"
                 HorizontalOptions="Center" VerticalOptions="Center" />
        </CollectionView.EmptyView>
      </CollectionView>

    </RefreshView>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 2: Status bar                                   -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Grid Grid.Row="2" HeightRequest="24"
          BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2B2B2B}">
      <Label Text="{Binding StatusMessage}"
             Padding="8,0" FontSize="10" Opacity="0.5"
             VerticalOptions="Center" HorizontalOptions="Start"
             TextColor="{AppThemeBinding Light=#444444, Dark=#AAAAAA}" />
      <ActivityIndicator IsRunning="{Binding IsLoading}"
                         IsVisible="{Binding IsLoading}"
                         HeightRequest="16" WidthRequest="16"
                         HorizontalOptions="End" VerticalOptions="Center"
                         Margin="8,0" />
    </Grid>

  </Grid>
</ContentPage>
