<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SaturdayPulse.Models"
             xmlns:viewmodels="clr-namespace:SaturdayPulse.ViewModels"
             xmlns:local="clr-namespace:SaturdayPulse.Converters"
             xmlns:vm="clr-namespace:SaturdayPulse.ViewModels"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Charts;assembly=Syncfusion.Maui.Charts"
             x:Class="SaturdayPulse.Views.ProjectionsPage"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False">

  <Grid RowDefinitions="Auto,*,24">

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 0: Title Game | Playoffs | Bowls | Sandbox      -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Grid Grid.Row="0"
          ColumnDefinitions="*,*,*,*"
          BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#1E1E1E}"
          Padding="8,4">

      <Label Grid.Column="0" Text="Title Games"
             FontSize="13" FontAttributes="Bold"
             HorizontalOptions="Center" VerticalOptions="Center">
        <Label.Triggers>
          <DataTrigger TargetType="Label" Binding="{Binding IsChampionshipView}" Value="True">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
            <Setter Property="TextDecorations" Value="Underline" />
          </DataTrigger>
          <DataTrigger TargetType="Label" Binding="{Binding IsChampionshipView}" Value="False">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#888888, Dark=#666666}" />
            <Setter Property="TextDecorations" Value="None" />
          </DataTrigger>
        </Label.Triggers>
        <Label.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SelectViewCommand}" CommandParameter="Championship" />
        </Label.GestureRecognizers>
      </Label>

      <Label Grid.Column="1" Text="Playoffs"
             FontSize="13" FontAttributes="Bold"
             HorizontalOptions="Center" VerticalOptions="Center">
        <Label.Triggers>
          <DataTrigger TargetType="Label" Binding="{Binding IsPlayoffsView}" Value="True">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
            <Setter Property="TextDecorations" Value="Underline" />
          </DataTrigger>
          <DataTrigger TargetType="Label" Binding="{Binding IsPlayoffsView}" Value="False">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#888888, Dark=#666666}" />
            <Setter Property="TextDecorations" Value="None" />
          </DataTrigger>
        </Label.Triggers>
        <Label.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SelectViewCommand}" CommandParameter="Playoffs" />
        </Label.GestureRecognizers>
      </Label>

      <Label Grid.Column="2" Text="Bowls"
             FontSize="13" FontAttributes="Bold"
             HorizontalOptions="Center" VerticalOptions="Center">
        <Label.Triggers>
          <DataTrigger TargetType="Label" Binding="{Binding IsBowlsView}" Value="True">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
            <Setter Property="TextDecorations" Value="Underline" />
          </DataTrigger>
          <DataTrigger TargetType="Label" Binding="{Binding IsBowlsView}" Value="False">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#888888, Dark=#666666}" />
            <Setter Property="TextDecorations" Value="None" />
          </DataTrigger>
        </Label.Triggers>
        <Label.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SelectViewCommand}" CommandParameter="Bowls" />
        </Label.GestureRecognizers>
      </Label>

      <Label Grid.Column="3" Text="Sandbox"
             FontSize="13" FontAttributes="Bold"
             HorizontalOptions="Center" VerticalOptions="Center">
        <Label.Triggers>
          <DataTrigger TargetType="Label" Binding="{Binding IsSandboxView}" Value="True">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
            <Setter Property="TextDecorations" Value="Underline" />
          </DataTrigger>
          <DataTrigger TargetType="Label" Binding="{Binding IsSandboxView}" Value="False">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#888888, Dark=#666666}" />
            <Setter Property="TextDecorations" Value="None" />
          </DataTrigger>
        </Label.Triggers>
        <Label.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SelectViewCommand}" CommandParameter="Sandbox" />
        </Label.GestureRecognizers>
      </Label>

    </Grid>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 1: Content area with pull-to-refresh            -->
    <!-- ═══════════════════════════════════════════════════ -->
<!-- PLAYOFFS VIEW -->
    <RefreshView Grid.Row="1"
                 Command="{Binding LoadDataCommand}"
                 IsRefreshing="{Binding IsLoading}"
                 IsVisible="False">
      <RefreshView.Triggers>
        <DataTrigger TargetType="RefreshView" Binding="{Binding IsPlayoffsView}" Value="True">
          <Setter Property="IsVisible" Value="True" />
        </DataTrigger>
      </RefreshView.Triggers>

      <ScrollView>
        <VerticalStackLayout Spacing="0">

          <!-- No data message -->
          <Label IsVisible="{Binding HasPlayoffData, Converter={StaticResource InvertedBoolConverter}}"
                 Text="{Binding StatusMessage}"
                 FontSize="13" Opacity="0.6" HorizontalOptions="Center"
                 Margin="0,40,0,0"
                 TextColor="{AppThemeBinding Light=#888888, Dark=#777777}" />

          <!-- Bracket rounds -->
          <VerticalStackLayout IsVisible="{Binding HasPlayoffData}"
                               BindableLayout.ItemsSource="{Binding PlayoffRounds}"
                               Spacing="0">
            <BindableLayout.ItemTemplate>
              <DataTemplate x:DataType="vm:PlayoffRound">

                <VerticalStackLayout Spacing="0">

                  <!-- Round header -->
                  <Grid BackgroundColor="{AppThemeBinding Light=#6B4EAE, Dark=#2A2040}" Padding="12,8">
                    <Label Text="{Binding RoundLabel}"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="White" />
                  </Grid>

                  <!-- Days within this round -->
                  <VerticalStackLayout BindableLayout.ItemsSource="{Binding Days}" Spacing="0">
                    <BindableLayout.ItemTemplate>
                      <DataTemplate x:DataType="vm:PlayoffDayGroup">

                        <VerticalStackLayout Spacing="0">

                          <!-- Day header -->
                          <Grid BackgroundColor="{AppThemeBinding Light=#EBEBEB, Dark=#252525}"
                                Padding="10,4">
                            <Label Text="{Binding DateLabel}"
                                   FontSize="11" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                                   VerticalOptions="Center" />
                          </Grid>

                          <!-- Games on this day -->
                          <VerticalStackLayout BindableLayout.ItemsSource="{Binding Games}" Spacing="0">
                            <BindableLayout.ItemTemplate>
                              <DataTemplate x:DataType="models:GameResult">
                                <VerticalStackLayout Spacing="0">

                                  <!-- Away team -->
                                  <Grid ColumnDefinitions="*,60,96" Padding="6,5,10,2">
                                    <Label Grid.Column="0"
                                           Text="{Binding VisitorNameWithConf}"
                                           FontSize="13" VerticalOptions="Center"
                                           LineBreakMode="TailTruncation" />
                                    <Label Grid.Column="1"
                                           Text="{Binding DisplayVisitorScore}"
                                           FontSize="13" FontAttributes="Bold"
                                           HorizontalOptions="End" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
                                    <Label Grid.Column="2"
                                           Text="{Binding DisplayMargin}"
                                           FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                                  </Grid>

                                  <!-- Home team -->
                                  <Grid ColumnDefinitions="*,60,96" Padding="6,2,10,5">
                                    <Label Grid.Column="0"
                                           Text="{Binding HomeNameWithConf}"
                                           FontSize="13" VerticalOptions="Center"
                                           LineBreakMode="TailTruncation" />
                                    <Label Grid.Column="1"
                                           Text="{Binding DisplayHomeScore}"
                                           FontSize="13" FontAttributes="Bold"
                                           HorizontalOptions="End" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
                                    <Label Grid.Column="2"
                                           Text="{Binding DisplayOU}"
                                           FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                                  </Grid>

                                  <BoxView HeightRequest="1" Opacity="0.08"
                                           Color="{AppThemeBinding Light=Black, Dark=White}" />
                                </VerticalStackLayout>
                              </DataTemplate>
                            </BindableLayout.ItemTemplate>
                          </VerticalStackLayout>

                        </VerticalStackLayout>
                      </DataTemplate>
                    </BindableLayout.ItemTemplate>
                  </VerticalStackLayout>

                </VerticalStackLayout>

              </DataTemplate>
            </BindableLayout.ItemTemplate>
          </VerticalStackLayout>

        </VerticalStackLayout>
      </ScrollView>
    </RefreshView>

    <!-- BOWLS VIEW -->
    <RefreshView Grid.Row="1"
                 Command="{Binding LoadDataCommand}"
                 IsRefreshing="{Binding IsLoading}"
                 IsVisible="False">
      <RefreshView.Triggers>
        <DataTrigger TargetType="RefreshView" Binding="{Binding IsBowlsView}" Value="True">
          <Setter Property="IsVisible" Value="True" />
        </DataTrigger>
      </RefreshView.Triggers>

      <ScrollView>
        <VerticalStackLayout Spacing="0">

          <!-- No data message -->
          <Label IsVisible="{Binding HasBowlData, Converter={StaticResource InvertedBoolConverter}}"
                 Text="{Binding StatusMessage}"
                 FontSize="13" Opacity="0.6" HorizontalOptions="Center"
                 Margin="0,40,0,0"
                 TextColor="{AppThemeBinding Light=#888888, Dark=#777777}" />

          <!-- Bowl games by weekend then day -->
          <VerticalStackLayout IsVisible="{Binding HasBowlData}"
                               BindableLayout.ItemsSource="{Binding BowlWeekends}"
                               Spacing="0">
            <BindableLayout.ItemTemplate>
              <DataTemplate x:DataType="vm:BowlWeekendGroup">

                <VerticalStackLayout Spacing="0">

                  <!-- Weekend header — purple like playoff round header -->
                  <Grid BackgroundColor="{AppThemeBinding Light=#6B4EAE, Dark=#2A2040}" Padding="12,8">
                    <Label Text="{Binding WeekendLabel}"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="White" />
                  </Grid>

                  <!-- Days within this weekend -->
                  <VerticalStackLayout BindableLayout.ItemsSource="{Binding Days}" Spacing="0">
                    <BindableLayout.ItemTemplate>
                      <DataTemplate x:DataType="vm:BowlDayGroup">

                        <VerticalStackLayout Spacing="0">

                          <!-- Day header — gray like playoff day header -->
                          <Grid BackgroundColor="{AppThemeBinding Light=#EBEBEB, Dark=#252525}"
                                Padding="10,4">
                            <Label Text="{Binding DateLabel}"
                                   FontSize="11" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                                   VerticalOptions="Center" />
                          </Grid>

                          <!-- Games on this day -->
                          <VerticalStackLayout BindableLayout.ItemsSource="{Binding Games}" Spacing="0">
                            <BindableLayout.ItemTemplate>
                              <DataTemplate x:DataType="models:GameResult">
                                <VerticalStackLayout Spacing="0">

                                  <!-- Away team -->
                                  <Grid ColumnDefinitions="*,60,96" Padding="6,5,10,2">
                                    <Label Grid.Column="0"
                                           Text="{Binding VisitorNameWithConf}"
                                           FontSize="13" VerticalOptions="Center"
                                           LineBreakMode="TailTruncation" />
                                    <Label Grid.Column="1"
                                           Text="{Binding DisplayVisitorScore}"
                                           FontSize="13" FontAttributes="Bold"
                                           HorizontalOptions="End" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
                                    <Label Grid.Column="2"
                                           Text="{Binding DisplayMargin}"
                                           FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                                  </Grid>

                                  <!-- Home team -->
                                  <Grid ColumnDefinitions="*,60,96" Padding="6,2,10,5">
                                    <Label Grid.Column="0"
                                           Text="{Binding HomeNameWithConf}"
                                           FontSize="13" VerticalOptions="Center"
                                           LineBreakMode="TailTruncation" />
                                    <Label Grid.Column="1"
                                           Text="{Binding DisplayHomeScore}"
                                           FontSize="13" FontAttributes="Bold"
                                           HorizontalOptions="End" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
                                    <Label Grid.Column="2"
                                           Text="{Binding DisplayOU}"
                                           FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                                  </Grid>

                                  <BoxView HeightRequest="1" Opacity="0.08"
                                           Color="{AppThemeBinding Light=Black, Dark=White}" />
                                </VerticalStackLayout>
                              </DataTemplate>
                            </BindableLayout.ItemTemplate>
                          </VerticalStackLayout>

                        </VerticalStackLayout>
                      </DataTemplate>
                    </BindableLayout.ItemTemplate>
                  </VerticalStackLayout>

                </VerticalStackLayout>

              </DataTemplate>
            </BindableLayout.ItemTemplate>
          </VerticalStackLayout>

        </VerticalStackLayout>
      </ScrollView>
    </RefreshView>

    <!-- SANDBOX VIEW -->
    <ScrollView Grid.Row="1" IsVisible="False">
      <ScrollView.Triggers>
        <DataTrigger TargetType="ScrollView" Binding="{Binding IsSandboxView}" Value="True">
          <Setter Property="IsVisible" Value="True" />
        </DataTrigger>
      </ScrollView.Triggers>

      <VerticalStackLayout Spacing="0" BindingContext="{Binding Sandbox}">

        <!-- Status -->
        <Label Text="{Binding StatusMessage}"
               FontSize="11" Opacity="0.6" Padding="12,8"
               TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />

        <!-- ── TEAM A — inline label + selector ── -->
        <Grid ColumnDefinitions="Auto,*,Auto,Auto" Padding="12,6,12,2" ColumnSpacing="6">

          <Label Grid.Column="0" Text="Team A:" FontSize="11" FontAttributes="Bold"
                 TextColor="{AppThemeBinding Light=#888888, Dark=#777777}"
                 VerticalOptions="Center" />

          <Grid Grid.Column="1" ColumnDefinitions="Auto,Auto,*">
            <Grid.GestureRecognizers>
              <TapGestureRecognizer Command="{Binding SelectTeamACommand}" />
            </Grid.GestureRecognizers>
            <Label Grid.Column="0" Text="{Binding TeamALabel}"
                   FontSize="13" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                   VerticalOptions="Center" LineBreakMode="TailTruncation" />
            <Label Grid.Column="1" Text=" ▾" FontSize="14"
                   TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                   VerticalOptions="Center" />
          </Grid>

          <Label Grid.Column="2" Text="Year:" FontSize="11" FontAttributes="Bold"
                 TextColor="{AppThemeBinding Light=#888888, Dark=#777777}"
                 VerticalOptions="Center" Margin="8,0,0,0" />

          <Grid Grid.Column="3" ColumnDefinitions="Auto,Auto">
            <Grid.GestureRecognizers>
              <TapGestureRecognizer Command="{Binding SelectYearACommand}" />
            </Grid.GestureRecognizers>
            <Label Grid.Column="0" FontSize="13" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                   VerticalOptions="Center">
              <Label.Text><Binding Path="TeamAYear" StringFormat="{}{0}" /></Label.Text>
            </Label>
            <Label Grid.Column="1" Text=" ▾" FontSize="14"
                   TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                   VerticalOptions="Center" />
          </Grid>

        </Grid>

        <!-- ── TEAM B — inline label + selector ── -->
        <Grid ColumnDefinitions="Auto,*,Auto,Auto" Padding="12,4,12,2" ColumnSpacing="6">

          <Label Grid.Column="0" Text="Team B:" FontSize="11" FontAttributes="Bold"
                 TextColor="{AppThemeBinding Light=#888888, Dark=#777777}"
                 VerticalOptions="Center" />

          <Grid Grid.Column="1" ColumnDefinitions="Auto,Auto,*">
            <Grid.GestureRecognizers>
              <TapGestureRecognizer Command="{Binding SelectTeamBCommand}" />
            </Grid.GestureRecognizers>
            <Label Grid.Column="0" Text="{Binding TeamBLabel}"
                   FontSize="13" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                   VerticalOptions="Center" LineBreakMode="TailTruncation" />
            <Label Grid.Column="1" Text=" ▾" FontSize="14"
                   TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                   VerticalOptions="Center" />
          </Grid>

          <Label Grid.Column="2" Text="Year:" FontSize="11" FontAttributes="Bold"
                 TextColor="{AppThemeBinding Light=#888888, Dark=#777777}"
                 VerticalOptions="Center" Margin="8,0,0,0" />

          <Grid Grid.Column="3" ColumnDefinitions="Auto,Auto">
            <Grid.GestureRecognizers>
              <TapGestureRecognizer Command="{Binding SelectYearBCommand}" />
            </Grid.GestureRecognizers>
            <Label Grid.Column="0" FontSize="13" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                   VerticalOptions="Center">
              <Label.Text><Binding Path="TeamBYear" StringFormat="{}{0}" /></Label.Text>
            </Label>
            <Label Grid.Column="1" Text=" ▾" FontSize="14"
                   TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                   VerticalOptions="Center" />
          </Grid>

        </Grid>

        <!-- ── SIMULATE MATCHUP — centered ── -->
        <Label Text="Simulate Matchup ›"
               FontSize="13" FontAttributes="Bold"
               HorizontalOptions="Center"
               Padding="12,10">
          <Label.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding RunMatchupCommand}" />
          </Label.GestureRecognizers>
          <Label.Triggers>
            <DataTrigger TargetType="Label" Binding="{Binding CanRunMatchup}" Value="False">
              <Setter Property="TextColor" Value="{AppThemeBinding Light=#AAAAAA, Dark=#555555}" />
            </DataTrigger>
            <DataTrigger TargetType="Label" Binding="{Binding CanRunMatchup}" Value="True">
              <Setter Property="TextColor" Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
            </DataTrigger>
          </Label.Triggers>
        </Label>

        <!-- ── PREDICTION RESULT — Schedule/Scores style ── -->
        <VerticalStackLayout IsVisible="{Binding HasPrediction}" Spacing="0">

          <!-- Date header -->
          <Grid BackgroundColor="{AppThemeBinding Light=#EBEBEB, Dark=#252525}" Padding="10,4">
            <Label Text="Neutral Site · End-of-Season Ratings"
                   FontSize="11" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                   VerticalOptions="Center" />
          </Grid>

          <!-- Away (Team A) row -->
          <Grid ColumnDefinitions="32,*,60,96" Padding="6,5,10,2"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A1A2E}">
            <Label Grid.Column="0"
                   Text="{Binding Prediction.TeamYear}"
                   FontSize="10"
                   TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#555555}"
                   HorizontalOptions="Center" VerticalOptions="Center" />
            <Label Grid.Column="1" Text="{Binding Prediction.TeamName}"
                   FontSize="13" VerticalOptions="Center"
                   LineBreakMode="TailTruncation" />
            <Label Grid.Column="2" Text="{Binding Prediction.TeamScore}"
                   FontSize="13" FontAttributes="Bold"
                   HorizontalOptions="End" VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
            <Label Grid.Column="3" Text="{Binding Prediction.MarginDisplay}"
                   FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
          </Grid>

          <!-- Home (Team B) row -->
          <Grid ColumnDefinitions="32,*,60,96" Padding="6,2,10,5"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1A1A2E}">
            <Label Grid.Column="0"
                   Text="{Binding Prediction.OpponentYear}"
                   FontSize="10"
                   TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#555555}"
                   HorizontalOptions="Center" VerticalOptions="Center" />
            <Label Grid.Column="1" Text="{Binding Prediction.OpponentName}"
                   FontSize="13" VerticalOptions="Center"
                   LineBreakMode="TailTruncation" />
            <Label Grid.Column="2" Text="{Binding Prediction.OppScore}"
                   FontSize="13" FontAttributes="Bold"
                   HorizontalOptions="End" VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
            <Label Grid.Column="3">
              <Label.FormattedText>
                <FormattedString>
                  <Span Text="± " />
                  <Span Text="{Binding Prediction.MarginOfError, StringFormat='{0:F1}'}" />
                  <Span Text=" pts" />
                </FormattedString>
              </Label.FormattedText>
              <Label.FontSize>11</Label.FontSize>
              <Label.HorizontalOptions>End</Label.HorizontalOptions>
              <Label.VerticalOptions>Center</Label.VerticalOptions>
              <Label.TextColor>
                <AppThemeBinding Light="#666666" Dark="#999999" />
              </Label.TextColor>
            </Label>
          </Grid>

          <BoxView HeightRequest="1" Opacity="0.10"
                   Color="{AppThemeBinding Light=Black, Dark=White}" />

          <!-- Confidence + rivalry note -->
          <Grid ColumnDefinitions="*,*" Padding="6,3,10,4">
            <Label Grid.Column="0" Text="{Binding Prediction.Confidence}"
                   FontSize="10" Opacity="0.6"
                   TextColor="{AppThemeBinding Light=#444444, Dark=#AAAAAA}" />
            <Label Grid.Column="1" Text="{Binding Prediction.RivalryNote}"
                   FontSize="10" Opacity="0.6" HorizontalOptions="End"
                   TextColor="{AppThemeBinding Light=#444444, Dark=#AAAAAA}" />
          </Grid>

        </VerticalStackLayout>

        <!-- ── TEAM A RANKING CARD ── -->
        <VerticalStackLayout IsVisible="{Binding HasTeamA}" Spacing="0" Margin="0,8,0,0">

          <Grid BackgroundColor="{AppThemeBinding Light=#EBEBEB, Dark=#252525}" Padding="10,4">
            <Label FontSize="11" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                   VerticalOptions="Center">
              <Label.FormattedText>
                <FormattedString>
                  <Span Text="{Binding TeamARanking.TeamName}" />
                  <Span Text=" · " />
                  <Span Text="{Binding TeamAYear}" />
                </FormattedString>
              </Label.FormattedText>
            </Label>
          </Grid>

          <!-- Column headers -->
          <Grid ColumnDefinitions="44,22,*,55,70,60" Padding="4,2,0,2">
            <Label Grid.Column="3" Text="Rec" FontSize="10" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}" VerticalOptions="Center" />
            <Label Grid.Column="4" Text="Rating" FontSize="10" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}" VerticalOptions="Center" />
            <Label Grid.Column="5" Text="SOS" FontSize="10" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}" VerticalOptions="Center" />
          </Grid>

          <Grid Padding="4,3" ColumnDefinitions="44,22,*,55,70,60">
            <Grid Grid.Column="0" Padding="2,2" HeightRequest="26" WidthRequest="40"
                  HorizontalOptions="Center" VerticalOptions="Center">
              <BoxView CornerRadius="3"
                       Color="{Binding TeamARanking.IsTop25, Converter={StaticResource BoolToColorConverter}}" />
              <Label Text="{Binding TeamARanking.OverallRank}"
                     FontSize="11" FontAttributes="Bold" TextColor="White"
                     HorizontalOptions="Center" VerticalOptions="Center" />
            </Grid>
            <Label Grid.Column="1"
                   Text="{Binding TeamARanking.IsFollowed, Converter={StaticResource FollowTeamGlyphConverter}}"
                   TextColor="{Binding TeamARanking.IsFollowed, Converter={StaticResource FollowTeamColorConverter}}"
                   FontSize="{StaticResource TeamIconSize}"
                   VerticalOptions="Center" HorizontalOptions="Center" />
            <VerticalStackLayout Grid.Column="2" Spacing="0" VerticalOptions="Center">
              <Label Text="{Binding TeamARanking.TeamName}"
                     FontSize="13" LineBreakMode="TailTruncation" />
              <Label Text="{Binding TeamARanking.DisplayConferenceTier}"
                     FontSize="10" Opacity="0.6" LineBreakMode="TailTruncation" />
            </VerticalStackLayout>
            <Label Grid.Column="3" Text="{Binding TeamARanking.Record}"
                   FontSize="11" VerticalOptions="Center" />
            <Label Grid.Column="4" Text="{Binding TeamARanking.DisplayRank}"
                   FontSize="11" FontAttributes="Bold" VerticalOptions="Center" />
            <Label Grid.Column="5" Text="{Binding TeamARanking.DisplaySOS}"
                   FontSize="11" VerticalOptions="Center" />
          </Grid>

          <Grid ColumnDefinitions="*,*,*" Padding="4,2,8,2">
            <Label Grid.Column="0" IsVisible="{Binding TeamARanking.HasTrendData}"
                   FontSize="10" HorizontalOptions="Start"
                   TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
              <Label.FormattedText>
                <FormattedString>
                  <Span Text="Trend / Pedigree" /><Span Text="  " />
                  <Span Text="{Binding TeamARanking.TrendExpandIcon}" FontSize="8" />
                </FormattedString>
              </Label.FormattedText>
              <Label.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ToggleTrendACommand}" />
              </Label.GestureRecognizers>
            </Label>
            <Label Grid.Column="1" FontSize="10" HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
              <Label.FormattedText>
                <FormattedString>
                  <Span Text="Season Arc" /><Span Text="  " />
                  <Span Text="{Binding TeamARanking.ArcExpandIcon}" FontSize="8" />
                </FormattedString>
              </Label.FormattedText>
              <Label.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ToggleArcACommand}" />
              </Label.GestureRecognizers>
            </Label>
            <Label Grid.Column="2" IsVisible="{Binding TeamARanking.HasOffenseDefenseData}"
                   FontSize="10" HorizontalOptions="End"
                   TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
              <Label.FormattedText>
                <FormattedString>
                  <Span Text="Offense / Defense" /><Span Text="  " />
                  <Span Text="{Binding TeamARanking.StatsExpandIcon}" FontSize="8" />
                </FormattedString>
