<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SaturdayPulse.Models"
             xmlns:viewmodels="clr-namespace:SaturdayPulse.ViewModels"
             xmlns:vm="clr-namespace:SaturdayPulse.ViewModels"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Charts;assembly=Syncfusion.Maui.Charts"
             x:Class="SaturdayPulse.Views.ProjectionsPage"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False">

  <Grid RowDefinitions="Auto,*,24">

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 0: Title Game | Playoffs | Bowls | Sandbox      -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Grid Grid.Row="0"
          ColumnDefinitions="*,*,*,*"
          BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#1E1E1E}"
          Padding="8,4">

      <Label Grid.Column="0" Text="Title Games"
             FontSize="13" FontAttributes="Bold"
             HorizontalOptions="Center" VerticalOptions="Center">
        <Label.Triggers>
          <DataTrigger TargetType="Label" Binding="{Binding IsChampionshipView}" Value="True">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
            <Setter Property="TextDecorations" Value="Underline" />
          </DataTrigger>
          <DataTrigger TargetType="Label" Binding="{Binding IsChampionshipView}" Value="False">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#888888, Dark=#666666}" />
            <Setter Property="TextDecorations" Value="None" />
          </DataTrigger>
        </Label.Triggers>
        <Label.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SelectViewCommand}" CommandParameter="Championship" />
        </Label.GestureRecognizers>
      </Label>

      <Label Grid.Column="1" Text="Playoffs"
             FontSize="13" FontAttributes="Bold"
             HorizontalOptions="Center" VerticalOptions="Center">
        <Label.Triggers>
          <DataTrigger TargetType="Label" Binding="{Binding IsPlayoffsView}" Value="True">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
            <Setter Property="TextDecorations" Value="Underline" />
          </DataTrigger>
          <DataTrigger TargetType="Label" Binding="{Binding IsPlayoffsView}" Value="False">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#888888, Dark=#666666}" />
            <Setter Property="TextDecorations" Value="None" />
          </DataTrigger>
        </Label.Triggers>
        <Label.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SelectViewCommand}" CommandParameter="Playoffs" />
        </Label.GestureRecognizers>
      </Label>

      <Label Grid.Column="2" Text="Bowls"
             FontSize="13" FontAttributes="Bold"
             HorizontalOptions="Center" VerticalOptions="Center">
        <Label.Triggers>
          <DataTrigger TargetType="Label" Binding="{Binding IsBowlsView}" Value="True">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
            <Setter Property="TextDecorations" Value="Underline" />
          </DataTrigger>
          <DataTrigger TargetType="Label" Binding="{Binding IsBowlsView}" Value="False">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#888888, Dark=#666666}" />
            <Setter Property="TextDecorations" Value="None" />
          </DataTrigger>
        </Label.Triggers>
        <Label.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SelectViewCommand}" CommandParameter="Bowls" />
        </Label.GestureRecognizers>
      </Label>

      <Label Grid.Column="3" Text="Sandbox"
             FontSize="13" FontAttributes="Bold"
             HorizontalOptions="Center" VerticalOptions="Center">
        <Label.Triggers>
          <DataTrigger TargetType="Label" Binding="{Binding IsSandboxView}" Value="True">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
            <Setter Property="TextDecorations" Value="Underline" />
          </DataTrigger>
          <DataTrigger TargetType="Label" Binding="{Binding IsSandboxView}" Value="False">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#888888, Dark=#666666}" />
            <Setter Property="TextDecorations" Value="None" />
          </DataTrigger>
        </Label.Triggers>
        <Label.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SelectViewCommand}" CommandParameter="Sandbox" />
        </Label.GestureRecognizers>
      </Label>

    </Grid>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 1: Content area with pull-to-refresh            -->
    <!-- ═══════════════════════════════════════════════════ -->
<!-- PLAYOFFS VIEW -->
    <RefreshView Grid.Row="1"
                 Command="{Binding LoadDataCommand}"
                 IsRefreshing="{Binding IsLoading}"
                 IsVisible="False">
      <RefreshView.Triggers>
        <DataTrigger TargetType="RefreshView" Binding="{Binding IsPlayoffsView}" Value="True">
          <Setter Property="IsVisible" Value="True" />
        </DataTrigger>
      </RefreshView.Triggers>

      <ScrollView>
        <VerticalStackLayout Spacing="0">

          <!-- No data message -->
          <Label IsVisible="{Binding HasPlayoffData, Converter={StaticResource InvertedBoolConverter}}"
                 Text="{Binding StatusMessage}"
                 FontSize="13" Opacity="0.6" HorizontalOptions="Center"
                 Margin="0,40,0,0"
                 TextColor="{AppThemeBinding Light=#888888, Dark=#777777}" />

          <!-- Bracket rounds -->
          <VerticalStackLayout IsVisible="{Binding HasPlayoffData}"
                               BindableLayout.ItemsSource="{Binding PlayoffRounds}"
                               Spacing="0">
            <BindableLayout.ItemTemplate>
              <DataTemplate x:DataType="vm:PlayoffRound">

                <VerticalStackLayout Spacing="0">

                  <!-- Round header -->
                  <Grid BackgroundColor="{AppThemeBinding Light=#6B4EAE, Dark=#2A2040}" Padding="12,8">
                    <Label Text="{Binding RoundLabel}"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="White" />
                  </Grid>

                  <!-- Days within this round -->
                  <VerticalStackLayout BindableLayout.ItemsSource="{Binding Days}" Spacing="0">
                    <BindableLayout.ItemTemplate>
                      <DataTemplate x:DataType="vm:PlayoffDayGroup">

                        <VerticalStackLayout Spacing="0">

                          <!-- Day header -->
                          <Grid BackgroundColor="{AppThemeBinding Light=#EBEBEB, Dark=#252525}" Padding="12,5">
                            <Label Text="{Binding DateLabel}"
                                   FontSize="11" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}" />
                          </Grid>

                          <!-- Games on this day -->
                          <VerticalStackLayout BindableLayout.ItemsSource="{Binding Games}" Spacing="0">
                            <BindableLayout.ItemTemplate>
                              <DataTemplate x:DataType="models:GameResult">
                                <VerticalStackLayout Spacing="0">

                                  <!-- Away team -->
                                  <Grid ColumnDefinitions="*,60,96" Padding="16,6,12,2">
                                    <Label Grid.Column="0"
                                           Text="{Binding VisitorNameWithConf}"
                                           FontSize="13" FontAttributes="Bold"
                                           VerticalOptions="Center"
                                           LineBreakMode="TailTruncation" />
                                    <Label Grid.Column="1"
                                           Text="{Binding DisplayVisitorScore}"
                                           FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#444444, Dark=#BBBBBB}" />
                                    <Label Grid.Column="2"
                                           Text="{Binding DisplayMargin}"
                                           FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                                  </Grid>

                                  <!-- Home team -->
                                  <Grid ColumnDefinitions="*,60,96" Padding="16,2,12,8">
                                    <Label Grid.Column="0"
                                           Text="{Binding HomeNameWithConf}"
                                           FontSize="13" FontAttributes="Bold"
                                           VerticalOptions="Center"
                                           LineBreakMode="TailTruncation" />
                                    <Label Grid.Column="1"
                                           Text="{Binding DisplayHomeScore}"
                                           FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#444444, Dark=#BBBBBB}" />
                                    <Label Grid.Column="2"
                                           Text="{Binding DisplayOU}"
                                           FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                                  </Grid>

                                  <BoxView HeightRequest="1" Opacity="0.08"
                                           Color="{AppThemeBinding Light=Black, Dark=White}" />
                                </VerticalStackLayout>
                              </DataTemplate>
                            </BindableLayout.ItemTemplate>
                          </VerticalStackLayout>

                        </VerticalStackLayout>
                      </DataTemplate>
                    </BindableLayout.ItemTemplate>
                  </VerticalStackLayout>

                </VerticalStackLayout>

              </DataTemplate>
            </BindableLayout.ItemTemplate>
          </VerticalStackLayout>

        </VerticalStackLayout>
      </ScrollView>
    </RefreshView>

    <!-- BOWLS VIEW -->
    <RefreshView Grid.Row="1"
                 Command="{Binding LoadDataCommand}"
                 IsRefreshing="{Binding IsLoading}"
                 IsVisible="False">
      <RefreshView.Triggers>
        <DataTrigger TargetType="RefreshView" Binding="{Binding IsBowlsView}" Value="True">
          <Setter Property="IsVisible" Value="True" />
        </DataTrigger>
      </RefreshView.Triggers>

      <ScrollView>
        <VerticalStackLayout Spacing="0">

          <!-- No data message -->
          <Label IsVisible="{Binding HasBowlData, Converter={StaticResource InvertedBoolConverter}}"
                 Text="{Binding StatusMessage}"
                 FontSize="13" Opacity="0.6" HorizontalOptions="Center"
                 Margin="0,40,0,0"
                 TextColor="{AppThemeBinding Light=#888888, Dark=#777777}" />

          <!-- Bowl games by date -->
          <VerticalStackLayout IsVisible="{Binding HasBowlData}"
                               BindableLayout.ItemsSource="{Binding BowlDays}"
                               Spacing="0">
            <BindableLayout.ItemTemplate>
              <DataTemplate x:DataType="vm:BowlDayGroup">

                <VerticalStackLayout Spacing="0">
                  <!-- Date group header -->
                  <Grid BackgroundColor="{AppThemeBinding Light=#EBEBEB, Dark=#252525}" Padding="10,6">
                    <Label Text="{Binding DateLabel}" FontSize="12" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                  </Grid>

                  <!-- Games on this day -->
                  <VerticalStackLayout BindableLayout.ItemsSource="{Binding Games}" Spacing="0">
                    <BindableLayout.ItemTemplate>
                      <DataTemplate x:DataType="models:GameResult">
                        <VerticalStackLayout Spacing="0">

                          <!-- Away team -->
                          <Grid ColumnDefinitions="*,80,96" Padding="12,4,12,2">
                            <Label Grid.Column="0"
                                   Text="{Binding VisitorNameWithConf}"
                                   FontSize="13" FontAttributes="Bold"
                                   VerticalOptions="Center"
                                   LineBreakMode="TailTruncation" />
                            <Label Grid.Column="1"
                                   FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                                   Text="{Binding DisplayVisitorScore}"
                                   TextColor="{AppThemeBinding Light=#444444, Dark=#BBBBBB}" />
                            <Label Grid.Column="2"
                                   Text="{Binding DisplayMargin}"
                                   FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                          </Grid>

                          <!-- Home team -->
                          <Grid ColumnDefinitions="*,80,96" Padding="12,2,12,6">
                            <Label Grid.Column="0"
                                   Text="{Binding HomeNameWithConf}"
                                   FontSize="13" FontAttributes="Bold"
                                   VerticalOptions="Center"
                                   LineBreakMode="TailTruncation" />
                            <Label Grid.Column="1"
                                   FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                                   Text="{Binding DisplayHomeScore}"
                                   TextColor="{AppThemeBinding Light=#444444, Dark=#BBBBBB}" />
                            <Label Grid.Column="2"
                                   Text="{Binding DisplayOU}"
                                   FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                          </Grid>

                          <BoxView HeightRequest="1" Opacity="0.12"
                                   Color="{AppThemeBinding Light=Black, Dark=White}" />
                        </VerticalStackLayout>
                      </DataTemplate>
                    </BindableLayout.ItemTemplate>
                  </VerticalStackLayout>
                </VerticalStackLayout>

              </DataTemplate>
            </BindableLayout.ItemTemplate>
          </VerticalStackLayout>

        </VerticalStackLayout>
      </ScrollView>
    </RefreshView>

    <!-- SANDBOX VIEW (stub) -->
    <VerticalStackLayout Grid.Row="1"
                         IsVisible="False"
                         VerticalOptions="Center" HorizontalOptions="Center">
      <VerticalStackLayout.Triggers>
        <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding IsSandboxView}" Value="True">
          <Setter Property="IsVisible" Value="True" />
        </DataTrigger>
      </VerticalStackLayout.Triggers>
      <Label Text="Sandbox" FontSize="18" FontAttributes="Bold"
             HorizontalOptions="Center"
             TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
      <Label Text="Coming soon" FontSize="13" Opacity="0.5"
             HorizontalOptions="Center" Margin="0,4,0,0" />
    </VerticalStackLayout>

    <!-- TITLE GAME VIEW -->
    <RefreshView Grid.Row="1"
                 Command="{Binding RefreshCommand}"
                 IsVisible="{Binding IsChampionshipView}"
                 IsRefreshing="False">

      <CollectionView ItemsSource="{Binding Championships}">
        <CollectionView.ItemTemplate>
          <DataTemplate x:DataType="models:ChampionshipMatchup">
            <VerticalStackLayout Spacing="0">

              <Grid BackgroundColor="{AppThemeBinding Light=#EBEBEB, Dark=#252525}" Padding="10,5">
                <Label Text="{Binding Conference}" FontSize="12" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
              </Grid>

              <Grid ColumnDefinitions="*,120,90" Padding="12,6,16,3">
                <Label Grid.Column="0" Text="{Binding Qualifier1.TeamName}"
                       FontSize="12" FontAttributes="Bold"
                       VerticalOptions="Center" LineBreakMode="TailTruncation" />
                <Label Grid.Column="1"
                       FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=#444444, Dark=#BBBBBB}">
                  <Label.FormattedText>
                    <FormattedString>
                      <Span Text="A: " FontSize="9"
                            TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#666666}" />
                      <Span Text="{Binding Qualifier1.ActualConferenceRecord}" FontSize="11"
                            TextColor="{AppThemeBinding Light=#444444, Dark=#BBBBBB}" />
                      <Span Text="  P: " FontSize="9"
                            TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#666666}" />
                      <Span Text="{Binding Qualifier1.ConferenceRecord}" />
                    </FormattedString>
                  </Label.FormattedText>
                </Label>
                <!-- Score stub — server work pending -->
                <Label Grid.Column="2" Text="–"
                       FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=#999999, Dark=#555555}" />
              </Grid>

              <Grid ColumnDefinitions="*,120,90" Padding="12,3,16,6">
                <Label Grid.Column="0" Text="{Binding Qualifier2.TeamName}"
                       FontSize="12" FontAttributes="Bold"
                       VerticalOptions="Center" LineBreakMode="TailTruncation" />
                <Label Grid.Column="1"
                       FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=#444444, Dark=#BBBBBB}">
                  <Label.FormattedText>
                    <FormattedString>
                      <Span Text="A: " FontSize="9"
                            TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#666666}" />
                      <Span Text="{Binding Qualifier2.ActualConferenceRecord}" FontSize="11"
                            TextColor="{AppThemeBinding Light=#444444, Dark=#BBBBBB}" />
                      <Span Text="  P: " FontSize="9"
                            TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#666666}" />
                      <Span Text="{Binding Qualifier2.ConferenceRecord}" />
                    </FormattedString>
                  </Label.FormattedText>
                </Label>
                <!-- Score stub — server work pending -->
                <Label Grid.Column="2" Text="–"
                       FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=#999999, Dark=#555555}" />
              </Grid>

              <Grid ColumnDefinitions="*,*" Padding="12,2,16,6">
                <Label Grid.Column="0" IsVisible="{Binding HasTiebreaker}"
                       FontSize="10" TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
                  <Label.FormattedText>
                    <FormattedString>
                      <Span Text="{Binding TiebreakerSummary}" />
                      <Span Text="  " />
                      <Span Text="{Binding ExpandIcon}" FontSize="8" />
                    </FormattedString>
                  </Label.FormattedText>
                  <Label.GestureRecognizers>
                    <TapGestureRecognizer
                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleMatchupExpandCommand}"
                        CommandParameter="{Binding .}" />
                  </Label.GestureRecognizers>
                </Label>
                <Label Grid.Column="1" IsVisible="{Binding HasContenders}"
                       FontSize="10" HorizontalOptions="End"
                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
                  <Label.FormattedText>
                    <FormattedString>
                      <Span Text="Contenders" />
                      <Span Text="  " />
                      <Span Text="{Binding ContendersExpandIcon}" FontSize="8" />
                    </FormattedString>
                  </Label.FormattedText>
                  <Label.GestureRecognizers>
                    <TapGestureRecognizer
                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleContendersExpandCommand}"
                        CommandParameter="{Binding .}" />
                  </Label.GestureRecognizers>
                </Label>
              </Grid>

              <!-- Tiebreaker log -->
              <VerticalStackLayout IsVisible="{Binding IsExpanded}"
                                   BackgroundColor="{AppThemeBinding Light=#F5F0FF, Dark=#1A1520}"
                                   Padding="12,4,16,8" Spacing="2"
                                   BindableLayout.ItemsSource="{Binding TiebreakerLog}">
                <BindableLayout.ItemTemplate>
                  <DataTemplate x:DataType="x:String">
                    <Label Text="{Binding .}" FontSize="10"
                           TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}" />
                  </DataTemplate>
                </BindableLayout.ItemTemplate>
              </VerticalStackLayout>

              <!-- Contenders -->
              <VerticalStackLayout IsVisible="{Binding IsContendersExpanded}"
                                   BackgroundColor="{AppThemeBinding Light=#F0F5FF, Dark=#151A20}"
                                   Padding="12,4,16,8" Spacing="2"
                                   BindableLayout.ItemsSource="{Binding Contenders}">
                <BindableLayout.ItemTemplate>
                  <DataTemplate x:DataType="models:ChampionshipContender">
                    <Grid ColumnDefinitions="*,120" Padding="0,2">
                      <Label Grid.Column="0" Text="{Binding TeamName}"
                             FontSize="12" VerticalOptions="Center" />
                      <Label Grid.Column="1"
                             FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                             TextColor="{AppThemeBinding Light=#444444, Dark=#BBBBBB}">
                        <Label.FormattedText>
                          <FormattedString>
                            <Span Text="A: " FontSize="9"
                                  TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#666666}" />
                            <Span Text="{Binding ActualConferenceRecord}" FontSize="11"
                                  TextColor="{AppThemeBinding Light=#444444, Dark=#BBBBBB}" />
                            <Span Text="  P: " FontSize="9"
                                  TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#666666}" />
                            <Span Text="{Binding ConferenceRecord}" />
                          </FormattedString>
                        </Label.FormattedText>
                      </Label>
                    </Grid>
                  </DataTemplate>
                </BindableLayout.ItemTemplate>
              </VerticalStackLayout>

              <BoxView HeightRequest="1" Opacity="0.15"
                       Color="{AppThemeBinding Light=Black, Dark=White}" />

            </VerticalStackLayout>
          </DataTemplate>
        </CollectionView.ItemTemplate>
        <CollectionView.EmptyView>
          <Label Text="No championship data" FontSize="14"
                 HorizontalOptions="Center" VerticalOptions="Center" />
        </CollectionView.EmptyView>
      </CollectionView>

    </RefreshView>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 2: Status bar                                   -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Grid Grid.Row="2" HeightRequest="24"
          BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2B2B2B}">
      <Label Text="{Binding StatusMessage}"
             Padding="8,0" FontSize="10" Opacity="0.5"
             VerticalOptions="Center" HorizontalOptions="Start"
             TextColor="{AppThemeBinding Light=#444444, Dark=#AAAAAA}" />
</Grid>

  </Grid>
</ContentPage>
