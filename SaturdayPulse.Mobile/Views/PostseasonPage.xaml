<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SaturdayPulse.Models"
             xmlns:viewmodels="clr-namespace:SaturdayPulse.ViewModels"
             xmlns:local="clr-namespace:SaturdayPulse.Converters"
             xmlns:controls="clr-namespace:SaturdayPulse.Controls"
             xmlns:vm="clr-namespace:SaturdayPulse.ViewModels"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Charts;assembly=Syncfusion.Maui.Charts"
             x:Class="SaturdayPulse.Views.PostseasonPage"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False">

  <ContentPage.Resources>

    <!-- ════════════════════════════════════════════════════════════════ -->
    <!-- Reusable GameResult card — Schedule layout                       -->
    <!-- Used by Playoffs, Bowls, and Title Games for the scheduled game  -->
    <!-- ════════════════════════════════════════════════════════════════ -->
    <DataTemplate x:Key="GameResultCard" x:DataType="models:GameResult">
      <VerticalStackLayout Spacing="0">

        <!-- Game card body -->
        <Grid ColumnDefinitions="32,28,*,52,96"
              RowDefinitions="Auto,Auto"
              Padding="6,5,10,5"
              BackgroundColor="{Binding IsOddRow, Converter={StaticResource OddRowBackgroundConverter}}">

          <!-- Wk label + star game follow -->
          <VerticalStackLayout Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
                               Spacing="2" VerticalOptions="Center"
                               HorizontalOptions="Start">
            <Label Text="{Binding Week, StringFormat='Wk{0}'}"
                   FontSize="10"
                   TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#555555}"
                   HorizontalOptions="Start" />
            <controls:FollowGameIcon
                  IsFollowed="{Binding IsGameFavorited}"
                  VerticalOptions="Center" HorizontalOptions="Start">
              <controls:FollowGameIcon.GestureRecognizers>
                <TapGestureRecognizer
                      Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.TogglePersonalGameCommand}"
                      CommandParameter="{Binding .}" />
              </controls:FollowGameIcon.GestureRecognizers>
            </controls:FollowGameIcon>
          </VerticalStackLayout>

          <!-- Visitor heart -->
          <controls:FollowTeamIcon Grid.Row="0" Grid.Column="1"
                IsFollowed="{Binding VisitorIsFollowed}"
                VerticalOptions="Center" HorizontalOptions="Start">
            <controls:FollowTeamIcon.GestureRecognizers>
              <TapGestureRecognizer
                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleFollowCommand}"
                    CommandParameter="{Binding AwayId}" />
            </controls:FollowTeamIcon.GestureRecognizers>
          </controls:FollowTeamIcon>

          <Label Grid.Row="0" Grid.Column="2" Text="{Binding VisitorName}"
                 FontSize="13" VerticalOptions="Center" LineBreakMode="TailTruncation" />
          <Label Grid.Row="0" Grid.Column="3" Text="{Binding DisplayVisitorScore}"
                 FontSize="13" FontAttributes="Bold"
                 HorizontalOptions="End" VerticalOptions="Center"
                 TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
          <Label Grid.Row="0" Grid.Column="4" Text="{Binding DisplayMargin}"
                 FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                 TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />

          <!-- Home heart -->
          <controls:FollowTeamIcon Grid.Row="1" Grid.Column="1"
                IsFollowed="{Binding HomeIsFollowed}"
                VerticalOptions="Center" HorizontalOptions="Start">
            <controls:FollowTeamIcon.GestureRecognizers>
              <TapGestureRecognizer
                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleFollowCommand}"
                    CommandParameter="{Binding HomeId}" />
            </controls:FollowTeamIcon.GestureRecognizers>
          </controls:FollowTeamIcon>

          <Label Grid.Row="1" Grid.Column="2"
                 FontSize="13" VerticalOptions="Center" LineBreakMode="TailTruncation">
            <Label.FormattedText>
              <FormattedString>
                <Span Text="{Binding HomeName}" />
                <Span Text="{Binding NeutralIndicator}" FontSize="10"
                      TextColor="{AppThemeBinding Light=#999999, Dark=#666666}" />
              </FormattedString>
            </Label.FormattedText>
          </Label>
          <Label Grid.Row="1" Grid.Column="3" Text="{Binding DisplayHomeScore}"
                 FontSize="13" FontAttributes="Bold"
                 HorizontalOptions="End" VerticalOptions="Center"
                 TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
          <Label Grid.Row="1" Grid.Column="4" Text="{Binding DisplayOU}"
                 FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                 TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />

        </Grid>

        <!-- Details toggle bar -->
        <Grid ColumnDefinitions="*" Padding="6,2,6,2"
              BackgroundColor="{Binding IsOddRow, Converter={StaticResource OddRowBackgroundConverter}}">
          <Label FontSize="10" HorizontalOptions="Center"
                 TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                 IsVisible="{Binding ShowDetails}">
            <Label.FormattedText>
              <FormattedString>
                <Span Text="Details " />
                <Span Text="{Binding DetailsExpandIcon}" FontSize="8" />
              </FormattedString>
            </Label.FormattedText>
            <Label.GestureRecognizers>
              <TapGestureRecognizer
                  Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleDetailsCommand}"
                  CommandParameter="{Binding .}" />
            </Label.GestureRecognizers>
          </Label>
        </Grid>

        <!-- Expanded details panel -->
        <VerticalStackLayout IsVisible="{Binding IsDetailsExpanded}"
                             Spacing="0"
                             BackgroundColor="{AppThemeBinding Light=#F0EBFF, Dark=#1A1520}">

          <!-- Vegas Lines section -->
          <VerticalStackLayout IsVisible="{Binding VegasLines.HasLines}" Spacing="0">

            <Grid ColumnDefinitions="48,70,60,*" Padding="6,6,6,2" ColumnSpacing="4">
              <Label Grid.Column="0" Text="VEGAS"
                     FontSize="9" FontAttributes="Bold"
                     TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                     VerticalOptions="Center" />
              <Label Grid.Column="1" Text="— Spread —"
                     FontSize="9" Opacity="0.5" HorizontalOptions="Center" />
              <Label Grid.Column="2" Text="— O/U —"
                     FontSize="9" Opacity="0.5" HorizontalOptions="Center" />
              <Label Grid.Column="3" Text="— Money Line —"
                     FontSize="9" Opacity="0.5" HorizontalOptions="Center" />
            </Grid>

            <Grid ColumnDefinitions="48,70,60,*" Padding="6,1,6,1" ColumnSpacing="4">
              <Label Grid.Column="0" Text="Open:"
                     FontSize="9" Opacity="0.6" VerticalOptions="Center" />
              <Label Grid.Column="1" Text="{Binding VegasLines.DisplaySpreadOpen}"
                     FontSize="10" FontAttributes="Bold" HorizontalOptions="Center"
                     TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
              <Label Grid.Column="2" Text="{Binding VegasLines.DisplayOUOpen}"
                     FontSize="10" FontAttributes="Bold" HorizontalOptions="Center"
                     TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
              <Label Grid.Column="3" HorizontalOptions="Center" VerticalOptions="Center">
                <Label.FormattedText>
                  <FormattedString>
                    <Span Text="{Binding AwayName}" FontSize="8"
                          TextColor="{AppThemeBinding Light=#CCCCCC, Dark=#CCCCCC}" />
                    <Span Text=": " FontSize="8"
                          TextColor="{AppThemeBinding Light=#CCCCCC, Dark=#CCCCCC}" />
                    <Span Text="{Binding VegasLines.DisplayAwayMoneyline}"
                          FontSize="10" FontAttributes="Bold"
                          TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
                  </FormattedString>
                </Label.FormattedText>
              </Label>
            </Grid>

            <Grid ColumnDefinitions="48,70,60,*" Padding="6,1,6,6" ColumnSpacing="4">
              <Label Grid.Column="0" Text="Current:"
                     FontSize="9" Opacity="0.6" VerticalOptions="Center" />
              <Label Grid.Column="1" Text="{Binding VegasLines.DisplaySpread}"
                     FontSize="10" FontAttributes="Bold" HorizontalOptions="Center"
                     TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
              <Label Grid.Column="2" Text="{Binding VegasLines.DisplayOU}"
                     FontSize="10" FontAttributes="Bold" HorizontalOptions="Center"
                     TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
              <Label Grid.Column="3" HorizontalOptions="Center" VerticalOptions="Center">
                <Label.FormattedText>
                  <FormattedString>
                    <Span Text="{Binding HomeName}" FontSize="8"
                          TextColor="{AppThemeBinding Light=#CCCCCC, Dark=#CCCCCC}" />
                    <Span Text=": " FontSize="8"
                          TextColor="{AppThemeBinding Light=#CCCCCC, Dark=#CCCCCC}" />
                    <Span Text="{Binding VegasLines.DisplayHomeMoneyline}"
                          FontSize="10" FontAttributes="Bold"
                          TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
                  </FormattedString>
                </Label.FormattedText>
              </Label>
            </Grid>

            <BoxView HeightRequest="1" Opacity="0.08" Margin="6,0"
                     Color="{AppThemeBinding Light=Black, Dark=White}" />

          </VerticalStackLayout>

          <!-- Inter-division message -->
          <Label IsVisible="{Binding IsInterDivision}"
                 Text="Inter-division game — no ranking data available."
                 FontSize="9" Opacity="0.5"
                 HorizontalOptions="Center"
                 Padding="8,10,8,10" />

          <!-- Team comparison table -->
          <VerticalStackLayout IsVisible="{Binding HasStats}" Spacing="0">

            <Grid ColumnDefinitions="*,44,44,44,38,44,38,44"
                  Padding="8,6,8,0" ColumnSpacing="2">
              <Label Grid.Column="0" />
              <Label Grid.Column="1" />
              <Label Grid.Column="2" />
              <Label Grid.Column="3" />
              <Label Grid.Column="4" Grid.ColumnSpan="2"
                     Text="— Offense —"
                     FontSize="8" FontAttributes="Bold" Opacity="0.5"
                     HorizontalOptions="Center" />
              <Label Grid.Column="6" Grid.ColumnSpan="2"
                     Text="— Defense —"
                     FontSize="8" FontAttributes="Bold" Opacity="0.5"
                     HorizontalOptions="Center" />
            </Grid>

            <Grid ColumnDefinitions="*,44,44,44,38,44,38,44"
                  Padding="8,0,8,2" ColumnSpacing="2">
              <Label Grid.Column="0" Text="Team"     FontSize="8" FontAttributes="Bold" Opacity="0.5" />
              <Label Grid.Column="1" Text="Rec"      FontSize="8" FontAttributes="Bold" Opacity="0.5" HorizontalOptions="Center" />
              <Label Grid.Column="2" Text="Rating"   FontSize="8" FontAttributes="Bold" Opacity="0.5" HorizontalOptions="Center" />
              <Label Grid.Column="3" Text="SOS"      FontSize="8" FontAttributes="Bold" Opacity="0.5" HorizontalOptions="Center" />
              <Label Grid.Column="4" Text="Rank"     FontSize="8" FontAttributes="Bold" Opacity="0.5" HorizontalOptions="Center" />
              <Label Grid.Column="5" Text="Avg Pts"  FontSize="8" FontAttributes="Bold" Opacity="0.5" HorizontalOptions="Center" />
              <Label Grid.Column="6" Text="Rank"     FontSize="8" FontAttributes="Bold" Opacity="0.5" HorizontalOptions="Center" />
              <Label Grid.Column="7" Text="Avg Pts"  FontSize="8" FontAttributes="Bold" Opacity="0.5" HorizontalOptions="Center" />
            </Grid>

            <BoxView HeightRequest="1" Opacity="0.08" Margin="8,0"
                     Color="{AppThemeBinding Light=Black, Dark=White}" />

            <!-- Away team row -->
            <Grid ColumnDefinitions="*,44,44,44,38,44,38,44"
                  Padding="8,3,8,3" ColumnSpacing="2">
              <Label Grid.Column="0" Text="{Binding AwayStats.TeamName}"
                     FontSize="9" FontAttributes="Bold" LineBreakMode="TailTruncation"
                     TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
              <Label Grid.Column="1" Text="{Binding AwayStats.Record}"
                     FontSize="9" HorizontalOptions="Center" />
              <Label Grid.Column="2" Text="{Binding AwayStats.DisplayRating}"
                     FontSize="9" HorizontalOptions="Center"
                     TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
              <Label Grid.Column="3" Text="{Binding AwayStats.DisplaySOS}"
                     FontSize="9" HorizontalOptions="Center" />
              <Label Grid.Column="4" Text="{Binding AwayStats.DisplayOffRank}"
                     FontSize="9" HorizontalOptions="Center"
                     TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
              <Label Grid.Column="5" Text="{Binding AwayStats.DisplayPtsScored}"
                     FontSize="9" HorizontalOptions="Center" />
              <Label Grid.Column="6" Text="{Binding AwayStats.DisplayDefRank}"
                     FontSize="9" HorizontalOptions="Center"
                     TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
              <Label Grid.Column="7" Text="{Binding AwayStats.DisplayPtsAllowed}"
                     FontSize="9" HorizontalOptions="Center" />
            </Grid>

            <BoxView HeightRequest="1" Opacity="0.05" Margin="8,0"
                     Color="{AppThemeBinding Light=Black, Dark=White}" />

            <!-- Home team row -->
            <Grid ColumnDefinitions="*,44,44,44,38,44,38,44"
                  Padding="8,3,8,6" ColumnSpacing="2">
              <Label Grid.Column="0" Text="{Binding HomeStats.TeamName}"
                     FontSize="9" FontAttributes="Bold" LineBreakMode="TailTruncation"
                     TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
              <Label Grid.Column="1" Text="{Binding HomeStats.Record}"
                     FontSize="9" HorizontalOptions="Center" />
              <Label Grid.Column="2" Text="{Binding HomeStats.DisplayRating}"
                     FontSize="9" HorizontalOptions="Center"
                     TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
              <Label Grid.Column="3" Text="{Binding HomeStats.DisplaySOS}"
                     FontSize="9" HorizontalOptions="Center" />
              <Label Grid.Column="4" Text="{Binding HomeStats.DisplayOffRank}"
                     FontSize="9" HorizontalOptions="Center"
                     TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
              <Label Grid.Column="5" Text="{Binding HomeStats.DisplayPtsScored}"
                     FontSize="9" HorizontalOptions="Center" />
              <Label Grid.Column="6" Text="{Binding HomeStats.DisplayDefRank}"
                     FontSize="9" HorizontalOptions="Center"
                     TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
              <Label Grid.Column="7" Text="{Binding HomeStats.DisplayPtsAllowed}"
                     FontSize="9" HorizontalOptions="Center" />
            </Grid>

          </VerticalStackLayout>

        </VerticalStackLayout>

        <BoxView HeightRequest="1" Opacity="0.10"
                 Color="{AppThemeBinding Light=Black, Dark=White}" />

      </VerticalStackLayout>
    </DataTemplate>

  </ContentPage.Resources>

  <Grid RowDefinitions="Auto,*,24">

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 0: Title Games | Playoffs | Bowls               -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Grid Grid.Row="0"
          ColumnDefinitions="*,*,*"
          BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#1E1E1E}"
          Padding="8,4">

      <Label Grid.Column="0" Text="Title Games"
             FontSize="13" FontAttributes="Bold"
             HorizontalOptions="Center" VerticalOptions="Center">
        <Label.Triggers>
          <DataTrigger TargetType="Label" Binding="{Binding IsChampionshipView}" Value="True">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
            <Setter Property="TextDecorations" Value="Underline" />
          </DataTrigger>
          <DataTrigger TargetType="Label" Binding="{Binding IsChampionshipView}" Value="False">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#888888, Dark=#666666}" />
            <Setter Property="TextDecorations" Value="None" />
          </DataTrigger>
        </Label.Triggers>
        <Label.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SelectViewCommand}" CommandParameter="Championship" />
        </Label.GestureRecognizers>
      </Label>

      <Label Grid.Column="1" Text="Playoffs"
             FontSize="13" FontAttributes="Bold"
             HorizontalOptions="Center" VerticalOptions="Center">
        <Label.Triggers>
          <DataTrigger TargetType="Label" Binding="{Binding IsPlayoffsView}" Value="True">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
            <Setter Property="TextDecorations" Value="Underline" />
          </DataTrigger>
          <DataTrigger TargetType="Label" Binding="{Binding IsPlayoffsView}" Value="False">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#888888, Dark=#666666}" />
            <Setter Property="TextDecorations" Value="None" />
          </DataTrigger>
        </Label.Triggers>
        <Label.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SelectViewCommand}" CommandParameter="Playoffs" />
        </Label.GestureRecognizers>
      </Label>

      <Label Grid.Column="2" Text="Bowls"
             FontSize="13" FontAttributes="Bold"
             HorizontalOptions="Center" VerticalOptions="Center">
        <Label.Triggers>
          <DataTrigger TargetType="Label" Binding="{Binding IsBowlsView}" Value="True">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
            <Setter Property="TextDecorations" Value="Underline" />
          </DataTrigger>
          <DataTrigger TargetType="Label" Binding="{Binding IsBowlsView}" Value="False">
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#888888, Dark=#666666}" />
            <Setter Property="TextDecorations" Value="None" />
          </DataTrigger>
        </Label.Triggers>
        <Label.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SelectViewCommand}" CommandParameter="Bowls" />
        </Label.GestureRecognizers>
      </Label>

    </Grid>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 1: Content area                                  -->
    <!-- ═══════════════════════════════════════════════════ -->

    <!-- ─────────────────── PLAYOFFS VIEW ─────────────────── -->
    <RefreshView Grid.Row="1"
                 Command="{Binding RefreshCommand}"
                 IsRefreshing="{Binding IsLoading}"
                 IsVisible="False">
      <RefreshView.Triggers>
        <DataTrigger TargetType="RefreshView" Binding="{Binding IsPlayoffsView}" Value="True">
          <Setter Property="IsVisible" Value="True" />
        </DataTrigger>
      </RefreshView.Triggers>

      <ScrollView>
        <VerticalStackLayout Spacing="0">

          <Label IsVisible="{Binding HasPlayoffData, Converter={StaticResource InvertedBoolConverter}}"
                 Text="{Binding StatusMessage}"
                 FontSize="13" Opacity="0.6" HorizontalOptions="Center"
                 Margin="0,40,0,0"
                 TextColor="{AppThemeBinding Light=#888888, Dark=#777777}" />

          <VerticalStackLayout IsVisible="{Binding HasPlayoffData}"
                               BindableLayout.ItemsSource="{Binding PlayoffRounds}"
                               Spacing="0">
            <BindableLayout.ItemTemplate>
              <DataTemplate x:DataType="vm:PlayoffRound">
                <VerticalStackLayout Spacing="0">

                  <!-- Round header — tappable to collapse/expand -->
                  <Grid BackgroundColor="{AppThemeBinding Light=#6B4EAE, Dark=#2A2040}"
                        Padding="12,8" ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="{Binding RoundLabel}"
                           FontSize="13" FontAttributes="Bold" TextColor="White"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="{Binding ExpandIcon}"
                           FontSize="10" TextColor="White"
                           VerticalOptions="Center" />
                    <Grid.GestureRecognizers>
                      <TapGestureRecognizer
                          Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleRoundExpandCommand}"
                          CommandParameter="{Binding .}" />
                    </Grid.GestureRecognizers>
                  </Grid>

                  <!-- Days — collapsible -->
                  <VerticalStackLayout IsVisible="{Binding IsExpanded}"
                                       BindableLayout.ItemsSource="{Binding Days}" Spacing="0">
                    <BindableLayout.ItemTemplate>
                      <DataTemplate x:DataType="vm:PlayoffDayGroup">
                        <VerticalStackLayout Spacing="0">

                          <!-- Day header -->
                          <Grid BackgroundColor="{AppThemeBinding Light=#EBEBEB, Dark=#252525}"
                                Padding="10,4">
                            <Label Text="{Binding DateLabel}"
                                   FontSize="11" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                                   VerticalOptions="Center" />
                          </Grid>

                          <!-- Games — use the shared GameResultCard template -->
                          <VerticalStackLayout BindableLayout.ItemsSource="{Binding Games}" Spacing="0"
                                               BindableLayout.ItemTemplate="{StaticResource GameResultCard}" />

                        </VerticalStackLayout>
                      </DataTemplate>
                    </BindableLayout.ItemTemplate>
                  </VerticalStackLayout>

                </VerticalStackLayout>
              </DataTemplate>
            </BindableLayout.ItemTemplate>
          </VerticalStackLayout>

        </VerticalStackLayout>
      </ScrollView>
    </RefreshView>

    <!-- ─────────────────── BOWLS VIEW ─────────────────── -->
    <RefreshView Grid.Row="1"
                 Command="{Binding RefreshCommand}"
                 IsRefreshing="{Binding IsLoading}"
                 IsVisible="False">
      <RefreshView.Triggers>
        <DataTrigger TargetType="RefreshView" Binding="{Binding IsBowlsView}" Value="True">
          <Setter Property="IsVisible" Value="True" />
        </DataTrigger>
      </RefreshView.Triggers>

      <ScrollView>
        <VerticalStackLayout Spacing="0">

          <Label IsVisible="{Binding HasBowlData, Converter={StaticResource InvertedBoolConverter}}"
                 Text="{Binding StatusMessage}"
                 FontSize="13" Opacity="0.6" HorizontalOptions="Center"
                 Margin="0,40,0,0"
                 TextColor="{AppThemeBinding Light=#888888, Dark=#777777}" />

          <VerticalStackLayout IsVisible="{Binding HasBowlData}"
                               BindableLayout.ItemsSource="{Binding BowlWeekends}"
                               Spacing="0">
            <BindableLayout.ItemTemplate>
              <DataTemplate x:DataType="vm:BowlWeekendGroup">
                <VerticalStackLayout Spacing="0">

                  <!-- Weekend header — tappable to collapse/expand -->
                  <Grid BackgroundColor="{AppThemeBinding Light=#6B4EAE, Dark=#2A2040}"
                        Padding="12,8" ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="{Binding WeekendLabel}"
                           FontSize="13" FontAttributes="Bold" TextColor="White"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="{Binding ExpandIcon}"
                           FontSize="10" TextColor="White"
                           VerticalOptions="Center" />
                    <Grid.GestureRecognizers>
                      <TapGestureRecognizer
                          Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleWeekendExpandCommand}"
                          CommandParameter="{Binding .}" />
                    </Grid.GestureRecognizers>
                  </Grid>

                  <!-- Days — collapsible -->
                  <VerticalStackLayout IsVisible="{Binding IsExpanded}"
                                       BindableLayout.ItemsSource="{Binding Days}" Spacing="0">
                    <BindableLayout.ItemTemplate>
                      <DataTemplate x:DataType="vm:BowlDayGroup">
                        <VerticalStackLayout Spacing="0">

                          <!-- Day header -->
                          <Grid BackgroundColor="{AppThemeBinding Light=#EBEBEB, Dark=#252525}"
                                Padding="10,4">
                            <Label Text="{Binding DateLabel}"
                                   FontSize="11" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                                   VerticalOptions="Center" />
                          </Grid>

                          <!-- Games — same shared template -->
                          <VerticalStackLayout BindableLayout.ItemsSource="{Binding Games}" Spacing="0"
                                               BindableLayout.ItemTemplate="{StaticResource GameResultCard}" />

                        </VerticalStackLayout>
                      </DataTemplate>
                    </BindableLayout.ItemTemplate>
                  </VerticalStackLayout>

                </VerticalStackLayout>
              </DataTemplate>
            </BindableLayout.ItemTemplate>
          </VerticalStackLayout>

        </VerticalStackLayout>
      </ScrollView>
    </RefreshView>

    <!-- ─────────────────── TITLE GAMES VIEW ─────────────────── -->
    <RefreshView Grid.Row="1"
                 Command="{Binding RefreshCommand}"
                 IsRefreshing="{Binding IsLoading}"
                 IsVisible="False">
      <RefreshView.Triggers>
        <DataTrigger TargetType="RefreshView" Binding="{Binding IsChampionshipView}" Value="True">
          <Setter Property="IsVisible" Value="True" />
        </DataTrigger>
      </RefreshView.Triggers>

      <CollectionView ItemsSource="{Binding Championships}">
        <CollectionView.ItemTemplate>
          <DataTemplate x:DataType="models:ChampionshipMatchup">
            <VerticalStackLayout Spacing="0">

              <!-- Conference header -->
              <Grid BackgroundColor="{AppThemeBinding Light=#6B4EAE, Dark=#2A2040}" Padding="12,8">
                <Label Text="{Binding Conference}"
                       FontSize="13" FontAttributes="Bold" TextColor="White" />
              </Grid>

              <!-- Game card — renders only when CFBD has published the title game.
                   GameList is a zero/one-item list so BindableLayout draws nothing
                   when Game is null, or one card via the shared template when it is. -->
              <VerticalStackLayout Spacing="0"
                                   BindableLayout.ItemsSource="{Binding GameList}"
                                   BindableLayout.ItemTemplate="{StaticResource GameResultCard}" />

              <!-- Qualifier rows -->
              <Grid ColumnDefinitions="*,120" Padding="12,6,16,3">
                <Label Grid.Column="0" Text="{Binding Qualifier1.TeamName}"
                       FontSize="13" VerticalOptions="Center" LineBreakMode="TailTruncation" />
                <Label Grid.Column="1"
                       FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=#444444, Dark=#BBBBBB}">
                  <Label.FormattedText>
                    <FormattedString>
                      <Span Text="A: " FontSize="9"
                            TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#666666}" />
                      <Span Text="{Binding Qualifier1.ActualConferenceRecord}" FontSize="11"
                            TextColor="{AppThemeBinding Light=#444444, Dark=#BBBBBB}" />
                      <Span Text="  P: " FontSize="9"
                            TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#666666}" />
                      <Span Text="{Binding Qualifier1.ConferenceRecord}" />
                    </FormattedString>
                  </Label.FormattedText>
                </Label>
              </Grid>

              <Grid ColumnDefinitions="*,120" Padding="12,3,16,6">
                <Label Grid.Column="0" Text="{Binding Qualifier2.TeamName}"
                       FontSize="13" VerticalOptions="Center" LineBreakMode="TailTruncation" />
                <Label Grid.Column="1"
                       FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=#444444, Dark=#BBBBBB}">
                  <Label.FormattedText>
                    <FormattedString>
                      <Span Text="A: " FontSize="9"
                            TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#666666}" />
                      <Span Text="{Binding Qualifier2.ActualConferenceRecord}" FontSize="11"
                            TextColor="{AppThemeBinding Light=#444444, Dark=#BBBBBB}" />
                      <Span Text="  P: " FontSize="9"
                            TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#666666}" />
                      <Span Text="{Binding Qualifier2.ConferenceRecord}" />
                    </FormattedString>
                  </Label.FormattedText>
                </Label>
              </Grid>

              <!-- Tiebreaker + Contenders toggles -->
              <Grid ColumnDefinitions="*,*" Padding="12,2,16,6">
                <Label Grid.Column="0" IsVisible="{Binding HasTiebreaker}"
                       FontSize="10" TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
                  <Label.FormattedText>
                    <FormattedString>
                      <Span Text="{Binding TiebreakerSummary}" />
                      <Span Text="  " />
                      <Span Text="{Binding ExpandIcon}" FontSize="8" />
                    </FormattedString>
                  </Label.FormattedText>
                  <Label.GestureRecognizers>
                    <TapGestureRecognizer
                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleMatchupExpandCommand}"
                        CommandParameter="{Binding .}" />
                  </Label.GestureRecognizers>
                </Label>
                <Label Grid.Column="1" IsVisible="{Binding HasContenders}"
                       FontSize="10" HorizontalOptions="End"
                       TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
                  <Label.FormattedText>
                    <FormattedString>
                      <Span Text="Contenders" />
                      <Span Text="  " />
                      <Span Text="{Binding ContendersExpandIcon}" FontSize="8" />
                    </FormattedString>
                  </Label.FormattedText>
                  <Label.GestureRecognizers>
                    <TapGestureRecognizer
                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleContendersExpandCommand}"
                        CommandParameter="{Binding .}" />
                  </Label.GestureRecognizers>
                </Label>
              </Grid>

              <!-- Tiebreaker log -->
              <VerticalStackLayout IsVisible="{Binding IsExpanded}"
                                   BackgroundColor="{AppThemeBinding Light=#F5F0FF, Dark=#1A1520}"
                                   Padding="12,4,16,8" Spacing="2"
                                   BindableLayout.ItemsSource="{Binding TiebreakerLog}">
                <BindableLayout.ItemTemplate>
                  <DataTemplate x:DataType="x:String">
                    <Label Text="{Binding .}" FontSize="10"
                           TextColor="{AppThemeBinding Light=#555555, Dark=#AAAAAA}" />
                  </DataTemplate>
                </BindableLayout.ItemTemplate>
              </VerticalStackLayout>

              <!-- Contenders -->
              <VerticalStackLayout IsVisible="{Binding IsContendersExpanded}"
                                   BackgroundColor="{AppThemeBinding Light=#F0F5FF, Dark=#151A20}"
                                   Padding="12,4,16,8" Spacing="2"
                                   BindableLayout.ItemsSource="{Binding Contenders}">
                <BindableLayout.ItemTemplate>
                  <DataTemplate x:DataType="models:ChampionshipContender">
                    <Grid ColumnDefinitions="*,120" Padding="0,2">
                      <Label Grid.Column="0" Text="{Binding TeamName}"
                             FontSize="12" VerticalOptions="Center" />
                      <Label Grid.Column="1"
                             FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                             TextColor="{AppThemeBinding Light=#444444, Dark=#BBBBBB}">
                        <Label.FormattedText>
                          <FormattedString>
                            <Span Text="A: " FontSize="9"
                                  TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#666666}" />
                            <Span Text="{Binding ActualConferenceRecord}" FontSize="11"
                                  TextColor="{AppThemeBinding Light=#444444, Dark=#BBBBBB}" />
                            <Span Text="  P: " FontSize="9"
                                  TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#666666}" />
                            <Span Text="{Binding ConferenceRecord}" />
                          </FormattedString>
                        </Label.FormattedText>
                      </Label>
                    </Grid>
                  </DataTemplate>
                </BindableLayout.ItemTemplate>
              </VerticalStackLayout>

              <BoxView HeightRequest="1" Opacity="0.15"
                       Color="{AppThemeBinding Light=Black, Dark=White}" />

            </VerticalStackLayout>
          </DataTemplate>
        </CollectionView.ItemTemplate>
        <CollectionView.EmptyView>
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="20">
                <Label Text="{Binding EmptyMessage}" FontSize="14" Opacity="0.7"
                    HorizontalOptions="Center" Margin="0,10,0,0"/>
            </VerticalStackLayout>
        </CollectionView.EmptyView>
      </CollectionView>

    </RefreshView>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 2: Status bar                                   -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Grid Grid.Row="2" HeightRequest="24"
          BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2B2B2B}">
      <Label Text="{Binding StatusMessage}"
             Padding="8,0" FontSize="10" Opacity="0.5"
             VerticalOptions="Center" HorizontalOptions="Start"
             TextColor="{AppThemeBinding Light=#444444, Dark=#AAAAAA}" />
    </Grid>

  </Grid>
</ContentPage>
