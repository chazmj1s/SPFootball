<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SaturdayPulse.Models"
             xmlns:viewmodels="clr-namespace:SaturdayPulse.ViewModels"
             xmlns:controls="clr-namespace:SaturdayPulse.Controls"
             xmlns:chart="clr-namespace:Syncfusion.Maui.Charts;assembly=Syncfusion.Maui.Charts"
             x:Class="SaturdayPulse.Views.MyTeamsPage"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False">

  <!--
    NOTE on x:Name="ThisPage": the inline templates below call back via
    {Binding Source={x:Reference ThisPage}, Path=BindingContext.<Command>}
    — this page's root MUST keep that name for those command bindings to
    resolve. (Reverted from shared merged-dictionary templates back to
    inline — see note in SchedulePage.xaml/PowerRankingsPage.xaml.)
  -->


  <Grid RowDefinitions="Auto,*,24">

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 0: Team chip scroller — same visual/interaction  -->
    <!-- pattern as MainPage's Week strip. Tap-only; no swipe -->
    <!-- attached here (page swipe stays on tab switching).   -->
    <!-- ═══════════════════════════════════════════════════ -->
    <ScrollView Grid.Row="0"
                Orientation="Horizontal"
                HorizontalScrollBarVisibility="Never"
                BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#252525}">
      <HorizontalStackLayout Spacing="0" Padding="6,0"
                             BindableLayout.ItemsSource="{Binding Chips}">
        <BindableLayout.ItemTemplate>
          <DataTemplate x:DataType="viewmodels:TeamChipItem">
            <Grid Padding="2,0" MinimumWidthRequest="64">
              <VerticalStackLayout Spacing="0">
                <Label Text="{Binding TeamName}"
                       FontSize="13"
                       HorizontalOptions="Center" Padding="10,8"
                       LineBreakMode="TailTruncation">
                  <Label.Triggers>
                    <!-- Primary chip: bold + accent color, always -->
                    <DataTrigger TargetType="Label" Binding="{Binding IsPrimary}" Value="True">
                      <Setter Property="FontAttributes" Value="Bold" />
                    </DataTrigger>
                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                      <Setter Property="TextColor" Value="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                    </DataTrigger>
                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="False">
                      <Setter Property="TextColor" Value="{AppThemeBinding Light=#555555, Dark=#AAAAAA}" />
                    </DataTrigger>
                  </Label.Triggers>
                </Label>
                <BoxView HeightRequest="2" HorizontalOptions="Fill"
                         Color="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                         IsVisible="{Binding IsSelected}" />
              </VerticalStackLayout>

              <!-- Small primary indicator (★) above the label -->
              <Label Text="★" FontSize="8"
                     TextColor="{AppThemeBinding Light=#BF5700, Dark=#FFB870}"
                     HorizontalOptions="Center" VerticalOptions="Start"
                     Margin="0,0,0,0"
                     IsVisible="{Binding IsPrimary}" />

              <Grid.GestureRecognizers>
                <TapGestureRecognizer
                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.SelectTeamCommand}"
                    CommandParameter="{Binding TeamId}" />
              </Grid.GestureRecognizers>
            </Grid>
          </DataTemplate>
        </BindableLayout.ItemTemplate>
      </HorizontalStackLayout>
    </ScrollView>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 1: Pinned rankings card + scrollable schedule    -->
    <!-- Team card is now a plain static view (not templated) -->
    <!-- bound directly to SelectedTeamRanking, sitting in its -->
    <!-- own Auto row above the CollectionView — it no longer  -->
    <!-- scrolls with the game list.                            -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Grid Grid.Row="1" RowDefinitions="Auto,*">

      <!-- Pinned team card -->
      <Grid Grid.Row="0" IsVisible="{Binding HasSelectedTeamRanking}">

    <VerticalStackLayout Spacing="0">

      <!-- ── Column headers — static, no sort (unlike Rankings page) ── -->
      <Grid Padding="4,3"
            ColumnDefinitions="44,22,*,55,70,60"
            BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2B2B2B}">
        <Label Grid.Column="0" Text="Rank"   FontAttributes="Bold" FontSize="10" />
        <Label Grid.Column="1" Text="" />
        <Label Grid.Column="2" Text="Team"   FontAttributes="Bold" FontSize="10" />
        <Label Grid.Column="3" Text="Rec"    FontAttributes="Bold" FontSize="10" />
        <Label Grid.Column="4" Text="Rating" FontAttributes="Bold" FontSize="10" />
        <Label Grid.Column="5" Text="SOS"    FontAttributes="Bold" FontSize="10" />
      </Grid>

    <VerticalStackLayout Spacing="0" BindingContext="{Binding SelectedTeamRanking}">

      <!-- ── Main row ── -->
      <Grid Padding="4,3"
            ColumnDefinitions="44,22,*,55,70,60"
            BackgroundColor="{Binding IsOddRow, Converter={StaticResource OddRowBackgroundConverter}}">

        <!-- Rank badge -->
        <Grid Grid.Column="0"
              Padding="2,2"
              HeightRequest="26"
              WidthRequest="40"
              HorizontalOptions="Center"
              VerticalOptions="Center">
          <BoxView CornerRadius="3"
                   Color="{Binding IsTop25, Converter={StaticResource BoolToColorConverter}}" />
          <Label Text="{Binding OverallRank}"
                 FontSize="11" FontAttributes="Bold" TextColor="White"
                 HorizontalOptions="Center" VerticalOptions="Center" />
        </Grid>

        <!-- Heart: follow team -->
        <Label Grid.Column="1"
               Text="{Binding IsFollowed, Converter={StaticResource FollowTeamGlyphConverter}}"
               TextColor="{Binding IsFollowed, Converter={StaticResource FollowTeamColorConverter}}"
               FontSize="{StaticResource TeamIconSize}"
               VerticalOptions="Center" HorizontalOptions="Center">
          <Label.GestureRecognizers>
            <TapGestureRecognizer
                Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleFollowCommand}"
                CommandParameter="{Binding .}" />
          </Label.GestureRecognizers>
        </Label>

        <!-- Team + Conf · Tier -->
        <VerticalStackLayout Grid.Column="2" Spacing="0" VerticalOptions="Center">
          <Label Text="{Binding TeamName}"
                 FontSize="13" LineBreakMode="TailTruncation"/>
          <Label Text="{Binding DisplayConferenceTier}"
                 FontSize="10" Opacity="0.6" LineBreakMode="TailTruncation"/>
        </VerticalStackLayout>

        <Label Grid.Column="3" Text="{Binding Record}"
               FontSize="11" VerticalOptions="Center"/>
        <Label Grid.Column="4" Text="{Binding DisplayRank}"
               FontSize="11" FontAttributes="Bold" VerticalOptions="Center"/>
        <Label Grid.Column="5" Text="{Binding DisplaySOS}"
               FontSize="11" VerticalOptions="Center"/>

      </Grid>

      <!-- ── Toggle bar: Trend/Pedigree | Season Arc | Offense/Defense ── -->
      <Grid ColumnDefinitions="*,*,*"
            Padding="4,2,8,2"
            BackgroundColor="{Binding IsOddRow, Converter={StaticResource OddRowBackgroundConverter}}">

        <!-- LEFT: Trend / Pedigree -->
        <Label Grid.Column="0"
               IsVisible="{Binding HasTrendData}"
               FontSize="10" HorizontalOptions="Start"
               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
          <Label.FormattedText>
            <FormattedString>
              <Span Text="Trend / Pedigree" />
              <Span Text="  " />
              <Span Text="{Binding TrendExpandIcon}" FontSize="8" />
            </FormattedString>
          </Label.FormattedText>
          <Label.GestureRecognizers>
            <TapGestureRecognizer
                Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleTrendExpandCommand}"
                CommandParameter="{Binding .}" />
          </Label.GestureRecognizers>
        </Label>

        <!-- CENTER: Season Arc -->
        <Label Grid.Column="1"
               FontSize="10" HorizontalOptions="Center"
               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
          <Label.FormattedText>
            <FormattedString>
              <Span Text="Season Arc" />
              <Span Text="  " />
              <Span Text="{Binding ArcExpandIcon}" FontSize="8" />
            </FormattedString>
          </Label.FormattedText>
          <Label.GestureRecognizers>
            <TapGestureRecognizer
                Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleArcExpandCommand}"
                CommandParameter="{Binding .}" />
          </Label.GestureRecognizers>
        </Label>

        <!-- RIGHT: Offense / Defense -->
        <Label Grid.Column="2"
               IsVisible="{Binding HasOffenseDefenseData}"
               FontSize="10" HorizontalOptions="End"
               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
          <Label.FormattedText>
            <FormattedString>
              <Span Text="Offense / Defense" />
              <Span Text="  " />
              <Span Text="{Binding StatsExpandIcon}" FontSize="8" />
            </FormattedString>
          </Label.FormattedText>
          <Label.GestureRecognizers>
            <TapGestureRecognizer
                Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleStatsExpandCommand}"
                CommandParameter="{Binding .}" />
          </Label.GestureRecognizers>
        </Label>

      </Grid>

      <!-- ── Trend / Pedigree expanded panel (lazy) ── -->
      <controls:LazyContentView IsExpanded="{Binding IsTrendExpanded}">
        <controls:LazyContentView.LazyTemplate>
          <DataTemplate>
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#D8D8D8, Dark=#3A3A3A}"
                    BackgroundColor="{AppThemeBinding Light=#F8F8F8, Dark=#202020}"
                    Margin="4,0,4,6">
              <VerticalStackLayout Spacing="0">

                <Grid ColumnDefinitions="*,Auto,Auto" Padding="12,8,12,2">
                  <Label Grid.Column="0"
                         Text="Trend / Pedigree History"
                         FontSize="10" FontAttributes="Bold"
                         TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                  <Label Grid.Column="1"
                         Text="{Binding Record}"
                         FontSize="9" Opacity="0.6"
                         Margin="0,0,10,0" />
                  <VerticalStackLayout Grid.Column="2" Spacing="0">
                    <Label Text="{Binding TrendRating, StringFormat='Trend {0:F4}'}"
                           FontSize="9" FontAttributes="Bold"
                           HorizontalTextAlignment="End"
                           TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
                    <Label Text="{Binding PedigreeRating, StringFormat='Pedigree {0:F4}'}"
                           FontSize="9" FontAttributes="Bold"
                           HorizontalTextAlignment="End"
                           TextColor="{AppThemeBinding Light=#3D7AB5, Dark=#5FA8E8}" />
                  </VerticalStackLayout>
                </Grid>

                <chart:SfCartesianChart HeightRequest="160" Margin="8,0,8,8">
                  <chart:SfCartesianChart.XAxes>
                    <chart:CategoryAxis ShowMajorGridLines="False"
                                        LabelPlacement="BetweenTicks" />
                  </chart:SfCartesianChart.XAxes>
                  <chart:SfCartesianChart.YAxes>
                    <chart:NumericalAxis Minimum="0" Maximum="1.2"
                                         Interval="0.2"
                                         ShowMajorGridLines="True" />
                  </chart:SfCartesianChart.YAxes>
                  <chart:SplineSeries
                      ItemsSource="{Binding TrendPoints}"
                      XBindingPath="Index" YBindingPath="Value"
                      Label="Trend"
                      Fill="{AppThemeBinding Light=#7A4DFF, Dark=#B388FF}"
                      StrokeWidth="3.5" EnableTooltip="True" />
                  <chart:SplineSeries
                      ItemsSource="{Binding PedigreePoints}"
                      XBindingPath="Index" YBindingPath="Value"
                      Label="Pedigree"
                      Fill="{AppThemeBinding Light=#C89B3C, Dark=#FFD166}"
                      StrokeWidth="2.5" EnableTooltip="True" />
                  <chart:SfCartesianChart.Legend>
                    <chart:ChartLegend Placement="Bottom" />
                  </chart:SfCartesianChart.Legend>
                </chart:SfCartesianChart>

              </VerticalStackLayout>
            </Border>
          </DataTemplate>
        </controls:LazyContentView.LazyTemplate>
      </controls:LazyContentView>

      <!-- ── Season Arc expanded panel (lazy) ── -->
      <controls:LazyContentView IsExpanded="{Binding IsArcExpanded}">
        <controls:LazyContentView.LazyTemplate>
          <DataTemplate>
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#C8E6C9, Dark=#2E4A35}"
                    BackgroundColor="{AppThemeBinding Light=#F1F8F2, Dark=#1A2A1E}"
                    Margin="4,0,4,6">
              <VerticalStackLayout Spacing="0">

                <Grid ColumnDefinitions="*,Auto" Padding="12,8,12,2">
                  <Label Grid.Column="0"
                         Text="Season Arc"
                         FontSize="10" FontAttributes="Bold"
                         TextColor="{AppThemeBinding Light=#2E8B57, Dark=#4CAF84}" />
                  <Label Grid.Column="1"
                         Text="{Binding Record}"
                         FontSize="9" Opacity="0.6" />
                </Grid>

                <chart:SfCartesianChart HeightRequest="170" Margin="8,0,8,8">
                  <chart:SfCartesianChart.XAxes>
                    <chart:NumericalAxis ShowMajorGridLines="False"
                                         Minimum="1" Interval="2">
                      <chart:NumericalAxis.Title>
                        <chart:ChartAxisTitle Text="Week" FontSize="9" />
                      </chart:NumericalAxis.Title>
                    </chart:NumericalAxis>
                  </chart:SfCartesianChart.XAxes>
                  <chart:SfCartesianChart.YAxes>
                    <!-- Single shared axis — Rating/SOS/WinPct all fall in -1 to 2 range -->
                    <chart:NumericalAxis
                       Minimum="-1" Maximum="2" Interval="0.5"
                       ShowMajorGridLines="True" />
                  </chart:SfCartesianChart.YAxes>
                  <chart:SplineSeries
                      ItemsSource="{Binding ArcRankingPoints}"
                      XBindingPath="Index" YBindingPath="Value"
                      Label="Rating"
                      Fill="{AppThemeBinding Light=#7A4DFF, Dark=#B388FF}"
                      StrokeWidth="3" EnableTooltip="True" />
                  <chart:SplineSeries
                      ItemsSource="{Binding ArcSosPoints}"
                      XBindingPath="Index" YBindingPath="Value"
                      Label="SOS"
                      Fill="{AppThemeBinding Light=#FF4444, Dark=#FF6B6B}"
                      StrokeWidth="2.5" EnableTooltip="True" />
                  <chart:SplineSeries
                      ItemsSource="{Binding ArcWinPctPoints}"
                      XBindingPath="Index" YBindingPath="Value"
                      Label="Win %"
                      Fill="{AppThemeBinding Light=#FFE500, Dark=#FFE500}"
                      StrokeWidth="2" EnableTooltip="True" />
                  <chart:SfCartesianChart.Legend>
                    <chart:ChartLegend Placement="Bottom" />
                  </chart:SfCartesianChart.Legend>
                </chart:SfCartesianChart>

              </VerticalStackLayout>
            </Border>
          </DataTemplate>
        </controls:LazyContentView.LazyTemplate>
      </controls:LazyContentView>

      <!-- ── Offense / Defense expanded panel ── -->
      <!-- Labels only — no charts — IsVisible is fine here -->
      <VerticalStackLayout IsVisible="{Binding IsStatsExpanded}"
                           Spacing="0"
                           BackgroundColor="{AppThemeBinding Light=#F0EBFF, Dark=#1A1520}">

        <Grid ColumnDefinitions="*,*,*" Padding="8,6,8,4" ColumnSpacing="4">
          <VerticalStackLayout Grid.Column="0" Spacing="1">
            <Label Text="Offensive Rank" FontSize="9" Opacity="0.6" />
            <Label Text="{Binding OffensiveRankDisplay}"
                   FontSize="10" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
          </VerticalStackLayout>
          <VerticalStackLayout Grid.Column="1" Spacing="1">
            <Label Text="Avg. Points Scored" FontSize="9" Opacity="0.6" />
            <Label Text="{Binding AvgPointsScored, StringFormat='{0:F1}'}"
                   FontSize="10" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
          </VerticalStackLayout>
          <VerticalStackLayout Grid.Column="2" Spacing="1">
            <Label Text="Offensive Index (Std-Z)" FontSize="9" Opacity="0.6" />
            <Label Text="{Binding OffensiveZScore, StringFormat='{0:F4}'}"
                   FontSize="10" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
          </VerticalStackLayout>
        </Grid>

        <BoxView HeightRequest="1" Opacity="0.08" Margin="8,0"
                 Color="{AppThemeBinding Light=Black, Dark=White}" />

        <Grid ColumnDefinitions="*,*,*" Padding="8,4,8,6" ColumnSpacing="4">
          <VerticalStackLayout Grid.Column="0" Spacing="1">
            <Label Text="Defensive Rank" FontSize="9" Opacity="0.6" />
            <Label Text="{Binding DefensiveRankDisplay}"
                   FontSize="10" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
          </VerticalStackLayout>
          <VerticalStackLayout Grid.Column="1" Spacing="1">
            <Label Text="Avg. Points Allowed" FontSize="9" Opacity="0.6" />
            <Label Text="{Binding AvgPointsAllowed, StringFormat='{0:F1}'}"
                   FontSize="10" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
          </VerticalStackLayout>
          <VerticalStackLayout Grid.Column="2" Spacing="1">
            <Label Text="Defensive Index (Std-Z)" FontSize="9" Opacity="0.6" />
            <Label Text="{Binding DefensiveZScore, StringFormat='{0:F4}'}"
                   FontSize="10" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
          </VerticalStackLayout>
        </Grid>

      </VerticalStackLayout>

      <BoxView HeightRequest="1" Opacity="0.10"
               Color="{AppThemeBinding Light=Black, Dark=White}" />

    </VerticalStackLayout>
    </VerticalStackLayout>
        </Grid>

      <RefreshView Grid.Row="1"
                   Command="{Binding RefreshCommand}"
                   IsRefreshing="{Binding IsBusy}">

        <CollectionView ItemsSource="{Binding SelectedTeamGames}"
                        ItemSizingStrategy="MeasureAllItems">

          <CollectionView.ItemTemplate>
<DataTemplate x:DataType="viewmodels:MyTeamsGameRow">
  <VerticalStackLayout Spacing="0">

    <!-- ── Compact single-line row ── -->
    <Grid ColumnDefinitions="Auto,*,100,100"
          Padding="6,0,8,0" ColumnSpacing="6">

      <Grid.Triggers>
        <DataTrigger TargetType="Grid" Binding="{Binding IsSelectedWeek}" Value="True">
          <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F0EBFF, Dark=#2A2040}" />
        </DataTrigger>
        <DataTrigger TargetType="Grid" Binding="{Binding IsSelectedWeek}" Value="False">
          <Setter Property="BackgroundColor" Value="Transparent" />
        </DataTrigger>
      </Grid.Triggers>

      <!-- Tap anywhere on the row (that isn't the star/heart/Details link,
           which each capture their own tap) to jump the week selector to
           this game's week. -->
      <Grid.GestureRecognizers>
        <TapGestureRecognizer
            Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.SelectWeekCommand}"
            CommandParameter="{Binding Week}" />
      </Grid.GestureRecognizers>

      <!-- Star + date, tight group -->
      <Grid Grid.Column="0" ColumnDefinitions="Auto,Auto" ColumnSpacing="2">
        <controls:FollowGameIcon Grid.Column="0"
              IsFollowed="{Binding Game.IsGameFavorited}"
              VerticalOptions="Center" HorizontalOptions="Start">
          <controls:FollowGameIcon.GestureRecognizers>
            <TapGestureRecognizer
                  Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.TogglePersonalGameCommand}"
                  CommandParameter="{Binding Game}" />
          </controls:FollowGameIcon.GestureRecognizers>
        </controls:FollowGameIcon>
        <Label Grid.Column="1" Text="{Binding DateShort}"
               FontSize="11" Opacity="0.6"
               VerticalOptions="Center" />
      </Grid>

      <!-- @/vs + heart + opponent -->
      <Grid Grid.Column="1" ColumnDefinitions="Auto,Auto,*" ColumnSpacing="3">
        <Label Grid.Column="0" Text="{Binding AtPrefix}"
               FontSize="13" Opacity="0.55"
               VerticalOptions="Center" />
        <controls:FollowTeamIcon Grid.Column="1"
              IsFollowed="{Binding OpponentIsFollowed}"
              VerticalOptions="Center" HorizontalOptions="Start">
          <controls:FollowTeamIcon.GestureRecognizers>
            <TapGestureRecognizer
                  Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleFollowCommand}"
                  CommandParameter="{Binding OpponentTeamId}" />
          </controls:FollowTeamIcon.GestureRecognizers>
        </controls:FollowTeamIcon>
        <Label Grid.Column="2" Text="{Binding OpponentName}"
               FontSize="12" VerticalOptions="Center"
               LineBreakMode="TailTruncation" />
      </Grid>

      <!-- Result letter + Score — fixed-width column so it lines up across rows -->
      <Grid Grid.Column="2" ColumnDefinitions="Auto,*" ColumnSpacing="2">
        <Label Grid.Column="0" Text="{Binding ResultLetter}"
               FontSize="10" FontAttributes="Bold"
               VerticalOptions="Center">
          <Label.Triggers>
            <DataTrigger TargetType="Label" Binding="{Binding ResultLetter}" Value="(W)">
              <Setter Property="TextColor" Value="{AppThemeBinding Light=#2E7D32, Dark=#66BB6A}" />
            </DataTrigger>
            <DataTrigger TargetType="Label" Binding="{Binding ResultLetter}" Value="(L)">
              <Setter Property="TextColor" Value="{AppThemeBinding Light=#C62828, Dark=#EF5350}" />
            </DataTrigger>
            <DataTrigger TargetType="Label" Binding="{Binding ResultLetter}" Value="(T)">
              <Setter Property="TextColor" Value="{AppThemeBinding Light=#888888, Dark=#AAAAAA}" />
            </DataTrigger>
          </Label.Triggers>
        </Label>
        <Label Grid.Column="1" Text="{Binding ScoreLine}"
               FontSize="10" FontAttributes="Bold"
               VerticalOptions="Center" HorizontalTextAlignment="End"
               LineBreakMode="NoWrap"
               TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
      </Grid>

      <!-- Spread / O-U, stacked — fixed-width column, same reason -->
      <VerticalStackLayout Grid.Column="3" Spacing="0"
                           VerticalOptions="Center">
        <Label Text="{Binding SpreadLine}" FontSize="10" Opacity="0.65"
               HorizontalTextAlignment="End" />
        <Label Text="{Binding OULine}" FontSize="10" Opacity="0.65"
               HorizontalTextAlignment="End" />
      </VerticalStackLayout>

    </Grid>

    <!-- ── Details toggle ── -->
    <Grid ColumnDefinitions="*" Padding="6,0,8,4" IsVisible="{Binding Game.ShowDetails}">
      <Label FontSize="10" HorizontalOptions="Center"
             TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}">
        <Label.FormattedText>
          <FormattedString>
            <Span Text="Details " />
            <Span Text="{Binding Game.DetailsExpandIcon}" FontSize="8" />
          </FormattedString>
        </Label.FormattedText>
        <Label.GestureRecognizers>
          <TapGestureRecognizer
              Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleDetailsCommand}"
              CommandParameter="{Binding Game}" />
        </Label.GestureRecognizers>
      </Label>
    </Grid>

    <!-- ══════════════════════════════════════════════ -->
    <!-- Expanded details panel — same content/bindings  -->
    <!-- as the original card, prefixed with Game. since -->
    <!-- this row's x:DataType is MyTeamsGameRow, not     -->
    <!-- GameResult.                                       -->
    <!-- ══════════════════════════════════════════════ -->
    <VerticalStackLayout IsVisible="{Binding Game.IsDetailsExpanded}"
                         Spacing="0"
                         BackgroundColor="{AppThemeBinding Light=#F0EBFF, Dark=#1A1520}">

      <!-- ── Vegas Lines section ── -->
      <VerticalStackLayout IsVisible="{Binding Game.VegasLines.HasLines}" Spacing="0">

        <!-- Header row -->
        <Grid ColumnDefinitions="48,70,60,*" Padding="6,6,6,2" ColumnSpacing="4">
          <Label Grid.Column="0" Text="VEGAS"
                 FontSize="9" FontAttributes="Bold"
                 TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                 VerticalOptions="Center" />
          <Label Grid.Column="1" Text="— Spread —"
                 FontSize="9" Opacity="0.5" HorizontalOptions="Center" />
          <Label Grid.Column="2" Text="— O/U —"
                 FontSize="9" Opacity="0.5" HorizontalOptions="Center" />
          <Label Grid.Column="3" Text="— Money Line —"
                 FontSize="9" Opacity="0.5" HorizontalOptions="Center" />
        </Grid>

        <!-- Open row — away moneyline -->
        <Grid ColumnDefinitions="48,70,60,*" Padding="6,1,6,1" ColumnSpacing="4">
          <Label Grid.Column="0" Text="Open:"
                 FontSize="9" Opacity="0.6" VerticalOptions="Center" />
          <Label Grid.Column="1" Text="{Binding Game.VegasLines.DisplaySpreadOpen}"
                 FontSize="10" FontAttributes="Bold" HorizontalOptions="Center"
                 TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
          <Label Grid.Column="2" Text="{Binding Game.VegasLines.DisplayOUOpen}"
                 FontSize="10" FontAttributes="Bold" HorizontalOptions="Center"
                 TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
          <Label Grid.Column="3" HorizontalOptions="Center" VerticalOptions="Center">
            <Label.FormattedText>
              <FormattedString>
                <Span Text="{Binding Game.AwayName}" FontSize="8"
                      TextColor="{AppThemeBinding Light=#CCCCCC, Dark=#CCCCCC}" />
                <Span Text=": " FontSize="8"
                      TextColor="{AppThemeBinding Light=#CCCCCC, Dark=#CCCCCC}" />
                <Span Text="{Binding Game.VegasLines.DisplayAwayMoneyline}"
                      FontSize="10" FontAttributes="Bold"
                      TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
              </FormattedString>
            </Label.FormattedText>
          </Label>
        </Grid>

        <!-- Current row — home moneyline -->
        <Grid ColumnDefinitions="48,70,60,*" Padding="6,1,6,6" ColumnSpacing="4">
          <Label Grid.Column="0" Text="Current:"
                 FontSize="9" Opacity="0.6" VerticalOptions="Center" />
          <Label Grid.Column="1" Text="{Binding Game.VegasLines.DisplaySpread}"
                 FontSize="10" FontAttributes="Bold" HorizontalOptions="Center"
                 TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
          <Label Grid.Column="2" Text="{Binding Game.VegasLines.DisplayOU}"
                 FontSize="10" FontAttributes="Bold" HorizontalOptions="Center"
                 TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
          <Label Grid.Column="3" HorizontalOptions="Center" VerticalOptions="Center">
            <Label.FormattedText>
              <FormattedString>
                <Span Text="{Binding Game.HomeName}" FontSize="8"
                      TextColor="{AppThemeBinding Light=#CCCCCC, Dark=#CCCCCC}" />
                <Span Text=": " FontSize="8"
                      TextColor="{AppThemeBinding Light=#CCCCCC, Dark=#CCCCCC}" />
                <Span Text="{Binding Game.VegasLines.DisplayHomeMoneyline}"
                      FontSize="10" FontAttributes="Bold"
                      TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />
              </FormattedString>
            </Label.FormattedText>
          </Label>
        </Grid>

        <BoxView HeightRequest="1" Opacity="0.08" Margin="6,0"
                 Color="{AppThemeBinding Light=Black, Dark=White}" />

      </VerticalStackLayout>

      <!-- Inter-division message -->
      <Label IsVisible="{Binding Game.IsInterDivision}"
             Text="Inter-division game — no ranking data available."
             FontSize="9" Opacity="0.5"
             HorizontalOptions="Center"
             Padding="8,10,8,10" />

      <!-- ── Team comparison table ── -->
      <VerticalStackLayout IsVisible="{Binding Game.HasStats}" Spacing="0">

      <!-- Group header row -->
      <Grid ColumnDefinitions="*,44,44,44,38,44,38,44"
            Padding="8,6,8,0" ColumnSpacing="2">
        <Label Grid.Column="0" />
        <Label Grid.Column="1" />
        <Label Grid.Column="2" />
        <Label Grid.Column="3" />
        <Label Grid.Column="4" Grid.ColumnSpan="2"
               Text="— Offense —"
               FontSize="8" FontAttributes="Bold" Opacity="0.5"
               HorizontalOptions="Center" />
        <Label Grid.Column="6" Grid.ColumnSpan="2"
               Text="— Defense —"
               FontSize="8" FontAttributes="Bold" Opacity="0.5"
               HorizontalOptions="Center" />
      </Grid>

      <!-- Column headers -->
      <Grid ColumnDefinitions="*,44,44,44,38,44,38,44"
            Padding="8,0,8,2" ColumnSpacing="2">
        <Label Grid.Column="0" Text="Team"     FontSize="8" FontAttributes="Bold" Opacity="0.5" />
        <Label Grid.Column="1" Text="Rec"      FontSize="8" FontAttributes="Bold" Opacity="0.5" HorizontalOptions="Center" />
        <Label Grid.Column="2" Text="Rating"   FontSize="8" FontAttributes="Bold" Opacity="0.5" HorizontalOptions="Center" />
        <Label Grid.Column="3" Text="SOS"      FontSize="8" FontAttributes="Bold" Opacity="0.5" HorizontalOptions="Center" />
        <Label Grid.Column="4" Text="Rank"     FontSize="8" FontAttributes="Bold" Opacity="0.5" HorizontalOptions="Center" />
        <Label Grid.Column="5" Text="Avg Pts"  FontSize="8" FontAttributes="Bold" Opacity="0.5" HorizontalOptions="Center" />
        <Label Grid.Column="6" Text="Rank"     FontSize="8" FontAttributes="Bold" Opacity="0.5" HorizontalOptions="Center" />
        <Label Grid.Column="7" Text="Avg Pts"  FontSize="8" FontAttributes="Bold" Opacity="0.5" HorizontalOptions="Center" />
      </Grid>

      <BoxView HeightRequest="1" Opacity="0.08" Margin="8,0"
               Color="{AppThemeBinding Light=Black, Dark=White}" />

      <!-- Away team row -->
      <Grid ColumnDefinitions="*,44,44,44,38,44,38,44"
            Padding="8,3,8,3" ColumnSpacing="2">
        <Label Grid.Column="0" Text="{Binding Game.AwayStats.TeamName}"
               FontSize="9" FontAttributes="Bold" LineBreakMode="TailTruncation"
               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
        <Label Grid.Column="1" Text="{Binding Game.AwayStats.Record}"
               FontSize="9" HorizontalOptions="Center" />
        <Label Grid.Column="2" Text="{Binding Game.AwayStats.DisplayRating}"
               FontSize="9" HorizontalOptions="Center"
               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
        <Label Grid.Column="3" Text="{Binding Game.AwayStats.DisplaySOS}"
               FontSize="9" HorizontalOptions="Center" />
        <Label Grid.Column="4" Text="{Binding Game.AwayStats.DisplayOffRank}"
               FontSize="9" HorizontalOptions="Center"
               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
        <Label Grid.Column="5" Text="{Binding Game.AwayStats.DisplayPtsScored}"
               FontSize="9" HorizontalOptions="Center" />
        <Label Grid.Column="6" Text="{Binding Game.AwayStats.DisplayDefRank}"
               FontSize="9" HorizontalOptions="Center"
               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
        <Label Grid.Column="7" Text="{Binding Game.AwayStats.DisplayPtsAllowed}"
               FontSize="9" HorizontalOptions="Center" />
      </Grid>

      <BoxView HeightRequest="1" Opacity="0.05" Margin="8,0"
               Color="{AppThemeBinding Light=Black, Dark=White}" />

      <!-- Home team row -->
      <Grid ColumnDefinitions="*,44,44,44,38,44,38,44"
            Padding="8,3,8,6" ColumnSpacing="2">
        <Label Grid.Column="0" Text="{Binding Game.HomeStats.TeamName}"
               FontSize="9" FontAttributes="Bold" LineBreakMode="TailTruncation"
               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
        <Label Grid.Column="1" Text="{Binding Game.HomeStats.Record}"
               FontSize="9" HorizontalOptions="Center" />
        <Label Grid.Column="2" Text="{Binding Game.HomeStats.DisplayRating}"
               FontSize="9" HorizontalOptions="Center"
               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
        <Label Grid.Column="3" Text="{Binding Game.HomeStats.DisplaySOS}"
               FontSize="9" HorizontalOptions="Center" />
        <Label Grid.Column="4" Text="{Binding Game.HomeStats.DisplayOffRank}"
               FontSize="9" HorizontalOptions="Center"
               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
        <Label Grid.Column="5" Text="{Binding Game.HomeStats.DisplayPtsScored}"
               FontSize="9" HorizontalOptions="Center" />
        <Label Grid.Column="6" Text="{Binding Game.HomeStats.DisplayDefRank}"
               FontSize="9" HorizontalOptions="Center"
               TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}" />
        <Label Grid.Column="7" Text="{Binding Game.HomeStats.DisplayPtsAllowed}"
               FontSize="9" HorizontalOptions="Center" />
      </Grid>

      </VerticalStackLayout>

    </VerticalStackLayout>

    <BoxView HeightRequest="1" Opacity="0.10"
             Color="{AppThemeBinding Light=Black, Dark=White}" />

  </VerticalStackLayout>
</DataTemplate>
          </CollectionView.ItemTemplate>

          <CollectionView.EmptyView>
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="20">
              <Label Text="{Binding EmptyMessage}" FontSize="14" Opacity="0.7"
                     HorizontalOptions="Center" Margin="0,10,0,0"/>
            </VerticalStackLayout>
          </CollectionView.EmptyView>

        </CollectionView>

      </RefreshView>

    </Grid>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 2: Status bar                                   -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Grid Grid.Row="2" HeightRequest="24"
          BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2B2B2B}">
      <Label Text="{Binding StatusMessage}"
             Padding="8,0" FontSize="10" Opacity="0.5"
             VerticalOptions="Center" HorizontalOptions="Start"
             TextColor="{AppThemeBinding Light=#444444, Dark=#AAAAAA}" />
    </Grid>

  </Grid>
</ContentPage>
