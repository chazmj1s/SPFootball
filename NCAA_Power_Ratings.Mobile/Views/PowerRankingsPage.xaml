<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:NCAA_Power_Ratings.Mobile.Models"
             xmlns:controls="clr-namespace:NCAA_Power_Ratings.Mobile.Controls"
             xmlns:converters="clr-namespace:NCAA_Power_Ratings.Mobile.Converters"
             x:Class="NCAA_Power_Ratings.Mobile.Views.PowerRankingsPage"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False">

  <Grid RowDefinitions="Auto,Auto,*,24">

        <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 1: Column headers                               -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Grid Grid.Row="0"
          Padding="4,3"
          BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2B2B2B}"
          ColumnDefinitions="44,22,*,55,70,60">

      <Label Grid.Column="0" Text="Rank ↕" FontAttributes="Bold" FontSize="10">
        <Label.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SortColumnCommand}" CommandParameter="Rank"/>
        </Label.GestureRecognizers>
      </Label>
      <Label Grid.Column="1" Text="" />
      <Label Grid.Column="2" Text="Team ↕" FontAttributes="Bold" FontSize="10">
        <Label.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SortColumnCommand}" CommandParameter="Team"/>
        </Label.GestureRecognizers>
      </Label>
      <Label Grid.Column="3" Text="Rec ↕" FontAttributes="Bold" FontSize="10">
        <Label.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SortColumnCommand}" CommandParameter="Record"/>
        </Label.GestureRecognizers>
      </Label>
      <Label Grid.Column="4" Text="Rating ↕" FontAttributes="Bold" FontSize="10">
        <Label.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SortColumnCommand}" CommandParameter="Rating"/>
        </Label.GestureRecognizers>
      </Label>
      <Label Grid.Column="5" Text="SOS ↕" FontAttributes="Bold" FontSize="10">
        <Label.GestureRecognizers>
          <TapGestureRecognizer Command="{Binding SortColumnCommand}" CommandParameter="SOS"/>
        </Label.GestureRecognizers>
      </Label>

    </Grid>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 2: Rankings list                                -->
    <!-- ═══════════════════════════════════════════════════ -->
    <CollectionView Grid.Row="1"
                    ItemsSource="{Binding FilteredTeams}"
                    SelectionMode="None">

      <CollectionView.ItemTemplate>
        <DataTemplate x:DataType="models:TeamRanking">
          <Grid Padding="4,3"
                ColumnDefinitions="44,22,*,55,70,60"
                BackgroundColor="{Binding IsOddRow, Converter={StaticResource OddRowBackgroundConverter}}">

              <!-- Rank badge -->
              <Grid Grid.Column="0"
                    Padding="2,2"
                    HeightRequest="26"
                    WidthRequest="40"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                    <BoxView CornerRadius="3"
                             Color="{Binding IsTop25, Converter={StaticResource BoolToColorConverter}}" />
                    <Label Text="{Binding OverallRank}"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
              </Grid>

              <!-- Heart: follow team -->
              <Label Grid.Column="1"
                     Text="{Binding IsFollowed, Converter={StaticResource FollowTeamGlyphConverter}}"
                     TextColor="{Binding IsFollowed, Converter={StaticResource FollowTeamColorConverter}}"
                     FontSize="{StaticResource TeamIconSize}"
                     VerticalOptions="Center"
                     HorizontalOptions="Center">
                     <Label.GestureRecognizers>
                         <TapGestureRecognizer
                             Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleFollowCommand}"
                             CommandParameter="{Binding .}" />
                     </Label.GestureRecognizers>
              </Label>

              <!-- Team + Conf · Tier -->
              <VerticalStackLayout Grid.Column="2" Spacing="0" VerticalOptions="Center">
                <Label Text="{Binding TeamName}"
                       FontSize="12" FontAttributes="Bold" LineBreakMode="TailTruncation"/>
                <Label Text="{Binding DisplayConferenceTier}"
                       FontSize="10" Opacity="0.6" LineBreakMode="TailTruncation"/>
              </VerticalStackLayout>

              <Label Grid.Column="3" Text="{Binding Record}"
                     FontSize="11" VerticalOptions="Center"/>
              <Label Grid.Column="4" Text="{Binding DisplayRank}"
                     FontSize="11" FontAttributes="Bold" VerticalOptions="Center"/>
              <Label Grid.Column="5" Text="{Binding DisplaySOS}"
                     FontSize="11" VerticalOptions="Center"/>

          </Grid>
        </DataTemplate>
      </CollectionView.ItemTemplate>

      <CollectionView.EmptyView>
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="20">
          <Label Text="No teams found" FontSize="18" HorizontalOptions="Center"/>
          <Label Text="{Binding StatusMessage}" FontSize="14" Opacity="0.7"
                 HorizontalOptions="Center" Margin="0,10,0,0"/>
        </VerticalStackLayout>
      </CollectionView.EmptyView>

    </CollectionView>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 3: Status bar                                   -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Grid Grid.Row="3" HeightRequest="24"
          BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2B2B2B}">
      <Label Text="{Binding StatusMessage}"
             Padding="8,0" FontSize="10" Opacity="0.7"
             VerticalOptions="Center" HorizontalOptions="Start"/>
      <ActivityIndicator IsRunning="{Binding IsBusy}"
                         IsVisible="{Binding IsBusy}"
                         HeightRequest="16" WidthRequest="16"
                         HorizontalOptions="End" VerticalOptions="Center"
                         Margin="8,0"/>
    </Grid>

  </Grid>

</ContentPage>
