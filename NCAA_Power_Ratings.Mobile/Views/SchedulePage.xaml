<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:NCAA_Power_Ratings.Mobile.Models"
             x:Class="NCAA_Power_Ratings.Mobile.Views.SchedulePage"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False">

  <Grid RowDefinitions="Auto,*,24">

       <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 1: Games list                                   -->
    <!-- ═══════════════════════════════════════════════════ -->
    <ActivityIndicator Grid.Row="0"
                       IsRunning="{Binding IsLoading}"
                       IsVisible="{Binding IsLoading}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />

    <CollectionView Grid.Row="0"
                    ItemsSource="{Binding Games}"
                    IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">

      <CollectionView.ItemTemplate>
        <DataTemplate x:DataType="models:GameResult">
          <VerticalStackLayout Spacing="0">

            <!-- Date group header -->
            <Grid BackgroundColor="{AppThemeBinding Light=#EBEBEB, Dark=#252525}"
                  Padding="10,4,10,4"
                  IsVisible="{Binding ShowGroupHeader}">
              <Label Text="{Binding GroupHeader}"
                     FontSize="11" FontAttributes="Bold"
                     TextColor="{AppThemeBinding Light=#6B4EAE, Dark=#9B7EDE}"
                     VerticalOptions="Center" />
            </Grid>

            <!-- Game card -->
            <Grid ColumnDefinitions="32,28,*,52,96"
                  RowDefinitions="Auto,Auto"
                  Padding="6,5,10,5"
                  BackgroundColor="{Binding IsOddRow, Converter={StaticResource OddRowBackgroundConverter}}">

              <Label Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
                     Text="{Binding Week, StringFormat='Wk{0}'}"
                     FontSize="10"
                     TextColor="{AppThemeBinding Light=#AAAAAA, Dark=#555555}"
                     HorizontalOptions="Start" VerticalOptions="Center" />

              <!-- Visitor star -->
              <Label Grid.Row="0" Grid.Column="1"
                     Text="☆" FontSize="17"
                     HorizontalOptions="Center" VerticalOptions="Center">
                <Label.GestureRecognizers>
                  <TapGestureRecognizer
                      Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleFollowCommand}"
                      CommandParameter="{Binding VisitorId}" />
                </Label.GestureRecognizers>
                <Label.Triggers>
                  <DataTrigger TargetType="Label" Binding="{Binding VisitorIsFollowed}" Value="True">
                    <Setter Property="Text" Value="★" />
                    <Setter Property="TextColor" Value="{AppThemeBinding Light=#CC8800, Dark=#FFCC44}" />
                  </DataTrigger>
                  <DataTrigger TargetType="Label" Binding="{Binding VisitorIsFollowed}" Value="False">
                    <Setter Property="Text" Value="☆" />
                    <Setter Property="TextColor" Value="{AppThemeBinding Light=#BBBBBB, Dark=#555555}" />
                  </DataTrigger>
                </Label.Triggers>
              </Label>

              <Label Grid.Row="0" Grid.Column="2"
                     Text="{Binding VisitorName}"
                     FontSize="14" VerticalOptions="Center"
                     LineBreakMode="TailTruncation" />

              <Label Grid.Row="0" Grid.Column="3"
                     Text="{Binding DisplayVisitorScore}"
                     FontSize="13" FontAttributes="Bold"
                     HorizontalOptions="End" VerticalOptions="Center"
                     TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />

              <Label Grid.Row="0" Grid.Column="4"
                     Text="{Binding DisplayMargin}"
                     FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                     TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />

              <!-- Home star -->
              <Label Grid.Row="1" Grid.Column="1"
                     Text="☆" FontSize="17"
                     HorizontalOptions="Center" VerticalOptions="Center">
                <Label.GestureRecognizers>
                  <TapGestureRecognizer
                      Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleFollowCommand}"
                      CommandParameter="{Binding HomeId}" />
                </Label.GestureRecognizers>
                <Label.Triggers>
                  <DataTrigger TargetType="Label" Binding="{Binding HomeIsFollowed}" Value="True">
                    <Setter Property="Text" Value="★" />
                    <Setter Property="TextColor" Value="{AppThemeBinding Light=#CC8800, Dark=#FFCC44}" />
                  </DataTrigger>
                  <DataTrigger TargetType="Label" Binding="{Binding HomeIsFollowed}" Value="False">
                    <Setter Property="Text" Value="☆" />
                    <Setter Property="TextColor" Value="{AppThemeBinding Light=#BBBBBB, Dark=#555555}" />
                  </DataTrigger>
                </Label.Triggers>
              </Label>

              <Label Grid.Row="1" Grid.Column="2"
                     FontSize="14" VerticalOptions="Center"
                     LineBreakMode="TailTruncation">
                <Label.FormattedText>
                  <FormattedString>
                    <Span Text="{Binding HomeName}" />
                    <Span Text="{Binding NeutralIndicator}" FontSize="10"
                          TextColor="{AppThemeBinding Light=#999999, Dark=#666666}" />
                  </FormattedString>
                </Label.FormattedText>
              </Label>

              <Label Grid.Row="1" Grid.Column="3"
                     Text="{Binding DisplayHomeScore}"
                     FontSize="13" FontAttributes="Bold"
                     HorizontalOptions="End" VerticalOptions="Center"
                     TextColor="{AppThemeBinding Light=#222222, Dark=#EEEEEE}" />

              <Label Grid.Row="1" Grid.Column="4"
                     Text="{Binding DisplayOU}"
                     FontSize="11" HorizontalOptions="End" VerticalOptions="Center"
                     TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />

            </Grid>

            <BoxView HeightRequest="1" Opacity="0.10"
                     Color="{AppThemeBinding Light=Black, Dark=White}" />

          </VerticalStackLayout>
        </DataTemplate>
      </CollectionView.ItemTemplate>

      <CollectionView.EmptyView>
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="20">
          <Label Text="No games found" FontSize="16" HorizontalOptions="Center" />
        </VerticalStackLayout>
      </CollectionView.EmptyView>

    </CollectionView>

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ROW 2: Status bar                                   -->
    <!-- ═══════════════════════════════════════════════════ -->
    <Grid Grid.Row="1" HeightRequest="24"
          BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2B2B2B}">
      <Label Text="( ) = projected value"
             Padding="8,0" FontSize="10" Opacity="0.5"
             VerticalOptions="Center" HorizontalOptions="Start"
             TextColor="{AppThemeBinding Light=#444444, Dark=#AAAAAA}" />
      <ActivityIndicator IsRunning="{Binding IsLoading}"
                         IsVisible="{Binding IsLoading}"
                         HeightRequest="16" WidthRequest="16"
                         HorizontalOptions="End" VerticalOptions="Center"
                         Margin="8,0" />
    </Grid>

  </Grid>
</ContentPage>
