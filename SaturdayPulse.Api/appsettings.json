{
  "ConnectionStrings": {
    //"DefaultConnection": "Data Source=SaturdayPulse.db;mode=ReadOnly",
    "DefaultConnection": "Data Source=SaturdayPulse.db"
  },
  "CfbdApi": {
    "BaseUrl": "https://api.collegefootballdata.com/",
    "BearerToken": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CustomSettings": {
    "FilePath": "NCAA Raw Game Data"
  },
  "MetricsConfiguration": {
    "HomeFieldAdvantage": 2.5,
    "StandardSeasonGames": 12,
    "ExtraWinBump": 0.25,
    "ProjectedWinsHistoryYears": 10,
    "SosWeekThreshold": 6,
    "ProjectedWinsRoundingThreshold": 0.75,
    "DominantPerformanceThreshold": 0.5,
    "UnderperformedThreshold": -0.5,
    "MinimumMatchupGames": 10,
    "MaxVarianceRatio": 2.0
  }
}
